<Project>

  <PropertyGroup>
    <LangVersion>9</LangVersion>
    <Nullable>enable</Nullable>
    <Deterministic>false</Deterministic>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <InformationalVersion>1.0.0-beta.7.5</InformationalVersion>
    <Company>BIM-CA</Company>
    <Copyright>Copyright © BIM-CA 2026</Copyright>
  </PropertyGroup>

  <!-- Default to latest version if not specified -->
  <PropertyGroup Condition="'$(RevitVersion)' == ''">
    <RevitVersion>2026</RevitVersion>
  </PropertyGroup>

  <!-- Framework selection based on Revit version -->
  <!-- Revit 2024 = .NET Framework 4.8, Revit 2025+ = .NET 8 -->
  <PropertyGroup Condition="'$(RevitVersion)' == '2024'">
    <RevitTargetFramework>net48-windows</RevitTargetFramework>
  </PropertyGroup>
  <PropertyGroup Condition="'$(RevitVersion)' == '2025' Or '$(RevitVersion)' == '2026'">
    <RevitTargetFramework>net8.0-windows</RevitTargetFramework>
  </PropertyGroup>
  <PropertyGroup Condition="'$(RevitVersion)' == '2027'">
    <RevitTargetFramework>net10.0-windows</RevitTargetFramework>
  </PropertyGroup>

  <!-- Compilation symbol: REVIT2024, REVIT2025, or REVIT2026 -->
  <PropertyGroup>
    <DefineConstants>$(DefineConstants);REVIT$(RevitVersion)</DefineConstants>
    <RevitInstallDir>C:\Program Files\Autodesk\Revit $(RevitVersion)</RevitInstallDir>
  </PropertyGroup>

  <!-- Disable assembly info generation for Release builds to avoid MSBuild issues -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <!-- Revit API references — only included when IncludeRevitRefs=true -->
  <ItemGroup Condition="'$(IncludeRevitRefs)' == 'true'">
    <Reference Include="RevitAPI">
      <HintPath>$(RevitInstallDir)\RevitAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>$(RevitInstallDir)\RevitAPIUI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
