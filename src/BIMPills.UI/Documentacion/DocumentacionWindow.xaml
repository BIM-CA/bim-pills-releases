<Window x:Class="BIMPills.UI.Documentacion.DocumentacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Documentación"
        Width="500" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32" Margin="0,0,12,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel>
                    <TextBlock Text="Documentación"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="BIMPills"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Button DockPanel.Dock="Bottom"
                Content="Cerrar"
                Style="{StaticResource SecondaryButton}"
                Width="90"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>

        <!-- Empty state -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Document icon -->
                <Border Width="52" Height="52" CornerRadius="13"
                        Background="#F2F2F7"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,14">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                               FontSize="24" Foreground="#C7C7CC"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Próximamente"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Las herramientas de documentación estarán&#x0a;disponibles en una próxima actualización."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           LineHeight="18"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

    </DockPanel>
</Window>
