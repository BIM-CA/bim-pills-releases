<Window x:Class="BIMPills.UI.Documentacion.AcotadoVanosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Acotado de Vanos"
        Width="540" Height="780"
        MinWidth="480" MinHeight="600"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Step number circle style -->
            <Style x:Key="StepCircle" TargetType="Border">
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>

            <!-- Scheme card style -->
            <Style x:Key="SchemeCard" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- Scope chip style -->
            <Style x:Key="ScopeChip" TargetType="Border">
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- Preset button style -->
            <Style x:Key="PresetButton" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- ═══ HEADER ═══ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="20,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="Documentación › Vanos"
                           Foreground="#88FFFFFF" FontSize="11"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Dimension icon -->
                    <Canvas Width="20" Height="20" Margin="0,0,10,0">
                        <Line X1="2" Y1="10" X2="18" Y2="10" Stroke="#EF6337" StrokeThickness="1.5"/>
                        <Line X1="4" Y1="6" X2="8" Y2="14" Stroke="#EF6337" StrokeThickness="2"/>
                        <Line X1="12" Y1="6" X2="16" Y2="14" Stroke="#EF6337" StrokeThickness="2"/>
                    </Canvas>
                    <TextBlock Text="Acotado de Vanos"
                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <Border DockPanel.Dock="Bottom" Background="White"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Left"
                           Text="0 puertas detectadas"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar"
                            Style="{StaticResource SecondaryButton}"
                            Width="90"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ExecuteBtn"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ExecuteButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="14" Height="14" Margin="0,0,6,0">
                                <Polyline Points="3,7 6,10 11,4" Stroke="White" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                            <TextBlock Text="Acotar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT (scrollable) ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>

                <!-- ─── STEP 1: Alcance ─── -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Style="{StaticResource StepCircle}">
                            <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Alcance" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="¿En qué elementos aplicar el acotado?"
                               Style="{StaticResource CaptionText}" Margin="34,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="34,0,0,0">
                        <Border x:Name="ChipActiveView" Style="{StaticResource ScopeChip}"
                                Background="#FFF0EBE6" BorderBrush="{StaticResource AccentBrush}"
                                MouseLeftButtonDown="ScopeChip_Click" Tag="active-view">
                            <TextBlock Text="Vista activa" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource AccentBrush}" FontWeight="Medium"/>
                        </Border>
                        <Border x:Name="ChipSelection" Style="{StaticResource ScopeChip}"
                                MouseLeftButtonDown="ScopeChip_Click" Tag="selection">
                            <TextBlock Text="Selección" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- ─── STEP 2: Esquema de acotado ─── -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Style="{StaticResource StepCircle}">
                            <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Esquema de acotado" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Elige el patrón de cotas que se creará automáticamente para cada vano de puerta."
                               Style="{StaticResource CaptionText}" Margin="34,0,0,8" TextWrapping="Wrap"/>

                    <!-- Scheme: Opening Width -->
                    <Border x:Name="SchemeOpeningWidth" Style="{StaticResource SchemeCard}"
                            BorderBrush="{StaticResource AccentBrush}" Background="#FFFAF7F5"
                            Margin="34,0,0,6"
                            MouseLeftButtonDown="SchemeCard_Click" Tag="opening-width">
                        <DockPanel>
                            <RadioButton x:Name="RadioOpening" DockPanel.Dock="Left"
                                         IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"
                                         GroupName="Scheme" Checked="SchemeRadio_Checked" Tag="opening-width"/>
                            <TextBlock DockPanel.Dock="Right" Text="Listo"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="10" FontWeight="Medium" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Ancho de vano" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="Cota entre caras internas del muro en cada puerta"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Scheme: Wall Chain -->
                    <Border x:Name="SchemeWallChain" Style="{StaticResource SchemeCard}"
                            Margin="34,0,0,6"
                            MouseLeftButtonDown="SchemeCard_Click" Tag="wall-chain">
                        <DockPanel>
                            <RadioButton x:Name="RadioChain" DockPanel.Dock="Left"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         GroupName="Scheme" Checked="SchemeRadio_Checked" Tag="wall-chain"/>
                            <TextBlock DockPanel.Dock="Right" Text="Listo"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="10" FontWeight="Medium" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Cadena de muro" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="Cota continua a lo largo del muro: extremos, vanos y muros intermedios"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Scheme: Distancia a eje (disabled) -->
                    <Border Style="{StaticResource SchemeCard}" Margin="34,0,0,0"
                            Opacity="0.5" IsEnabled="False">
                        <DockPanel>
                            <RadioButton DockPanel.Dock="Left" IsEnabled="False"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         GroupName="Scheme"/>
                            <TextBlock DockPanel.Dock="Right" Text="Próximo"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Distancia a eje" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="Cota desde grilla/eje más cercano al centro del vano"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- ─── STEP 3: Estilo de cota ─── -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Style="{StaticResource StepCircle}">
                            <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Estilo de cota" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Tipo de cota del proyecto que se utilizará para crear las dimensiones."
                               Style="{StaticResource CaptionText}" Margin="34,0,0,8" TextWrapping="Wrap"/>
                    <ComboBox x:Name="DimTypeCombo" Margin="34,0,0,0"
                              FontSize="13" FontFamily="Segoe UI"
                              Padding="10,8" Height="36"/>
                </StackPanel>

                <!-- ─── STEP 4: Distancia de la cota ─── -->
                <StackPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Style="{StaticResource StepCircle}">
                            <TextBlock Text="4" Foreground="White" FontSize="12" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Distancia de la cota" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Separación entre la línea de cota y el elemento acotado (en milímetros)."
                               Style="{StaticResource CaptionText}" Margin="34,0,0,8" TextWrapping="Wrap"/>

                    <DockPanel Margin="34,0,0,0">
                        <Border DockPanel.Dock="Right" Background="{StaticResource AlternateRowBrush}"
                                CornerRadius="6" Padding="10,4" Margin="10,0,0,0"
                                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="OffsetValueText" Text="150"
                                           FontSize="16" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text=" mm" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                            </StackPanel>
                        </Border>
                        <Slider x:Name="OffsetSlider"
                                Minimum="50" Maximum="500" Value="150"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="OffsetSlider_ValueChanged"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="34,8,0,0">
                        <Button Content="80" Style="{StaticResource PresetButton}"
                                Click="PresetButton_Click" Tag="80"/>
                        <Button Content="150" Style="{StaticResource PresetButton}"
                                Click="PresetButton_Click" Tag="150"
                                BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}"/>
                        <Button Content="250" Style="{StaticResource PresetButton}"
                                Click="PresetButton_Click" Tag="250"/>
                        <Button Content="400" Style="{StaticResource PresetButton}"
                                Click="PresetButton_Click" Tag="400"/>
                    </StackPanel>
                </StackPanel>

                <!-- ─── INFO BOX ─── -->
                <Border Background="#F0F7FF" CornerRadius="8" Padding="12,10" Margin="0,4,0,0"
                        BorderBrush="#D0E3F7" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#1565C0" Margin="0,0,10,0"
                                   VerticalAlignment="Top"/>
                        <TextBlock x:Name="InfoText" TextWrapping="Wrap"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#1565C0" LineHeight="18">
                            Se crearán cotas en la <Bold>vista activa</Bold> para cada puerta visible.
                            Las cotas existentes no serán duplicadas.
                        </TextBlock>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
