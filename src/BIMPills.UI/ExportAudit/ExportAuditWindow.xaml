<Window x:Class="BIMPills.UI.ExportAudit.ExportAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Exportar Informe"
        Width="540" Height="700"
        MinWidth="460" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Exportación"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Informe de Auditoría"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Exporta un informe HTML con hallazgos y recomendaciones"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer — Cerrar left, Exportar right -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>

                        <Button DockPanel.Dock="Right"
                                Content="Exportar HTML"
                                Style="{StaticResource SecondaryButton}"
                                Padding="18,0"
                                Click="Export_Click"/>
                    </DockPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,14">
                    <StackPanel>

                        <!-- Summary metrics -->
                        <TextBlock Text="Resumen del Modelo"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,10"
                                   FontFamily="Segoe UI"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <Border Padding="12,10" Background="White" CornerRadius="8"
                                        BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Salud del Modelo" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="HealthScoreDisplay"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="Segoe UI"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="12,10" Background="White" CornerRadius="8"
                                        BorderBrush="#E5E5EA" BorderThickness="0.5">
                                    <StackPanel>
                                        <TextBlock Text="Advertencias" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="WarningsDisplay"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="#FF3B30"
                                                   FontFamily="Segoe UI"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <Border Padding="12,10" Background="White" CornerRadius="8"
                                        BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Elementos sin Categoría" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="OrphansDisplay"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="#FF9500"
                                                   FontFamily="Segoe UI"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="12,10" Background="White" CornerRadius="8"
                                        BorderBrush="#E5E5EA" BorderThickness="0.5">
                                    <StackPanel>
                                        <TextBlock Text="Tamaño del Modelo" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="FileSizeDisplay"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontFamily="Segoe UI"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Report header info -->
                        <Border Padding="12,10" Background="White" CornerRadius="8"
                                BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="Encabezado del informe" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Título:"
                                               FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,10,6"/>
                                    <TextBox x:Name="TxtReportTitle" Grid.Row="0" Grid.Column="1"
                                             Padding="8,5" FontFamily="Segoe UI" FontSize="11"
                                             Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha producción:"
                                               FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,10,6"/>
                                    <TextBox x:Name="TxtProductionDate" Grid.Row="1" Grid.Column="1"
                                             Padding="8,5" FontFamily="Segoe UI" FontSize="11"
                                             Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Generado por:"
                                               FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="TxtGeneratedBy" Grid.Row="2" Grid.Column="1"
                                             Padding="8,5" FontFamily="Segoe UI" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Signature -->
                        <Border Padding="12,10" Background="White" CornerRadius="8"
                                BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Firma del informe" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre:"
                                               FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,10,6"/>
                                    <TextBox x:Name="TxtSignatureName" Grid.Row="0" Grid.Column="1"
                                             Padding="8,5" FontFamily="Segoe UI" FontSize="11"
                                             Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cargo:"
                                               FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="TxtSignatureRole" Grid.Row="1" Grid.Column="1"
                                             Padding="8,5" FontFamily="Segoe UI" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section selection -->
                        <Border Padding="12,10" Background="White" CornerRadius="8"
                                BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Secciones a incluir" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkHealthScore" Content="Puntuación de salud (desglose)" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkWarnings" Content="Advertencias" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkOrphans" Content="Elementos sin categoría" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkFamilies" Content="Familias más grandes" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkViews" Content="Vistas sin colocar" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkPurgeable" Content="Elementos purgables" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkRecommendations" Content="Recomendaciones" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                                <CheckBox x:Name="ChkMethodology" Content="Metodología de evaluación" Margin="0,4" IsChecked="True" FontFamily="Segoe UI" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Output path -->
                        <Border Padding="12,10" Background="White" CornerRadius="8"
                                BorderBrush="#E5E5EA" BorderThickness="0.5" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Carpeta de guardado" FontSize="11" Foreground="#8E8E93"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OutputPathBox" Grid.Column="0" Padding="8,6"
                                             VerticalAlignment="Center"
                                             FontFamily="Segoe UI" FontSize="11" IsReadOnly="True"
                                             Background="#FAFAFA"/>
                                    <Button Grid.Column="1" Content="Examinar..."
                                            Margin="8,0,0,0"
                                            Style="{StaticResource TertiaryButton}"
                                            Padding="12,6" FontSize="11"
                                            Click="BrowseFolder_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
