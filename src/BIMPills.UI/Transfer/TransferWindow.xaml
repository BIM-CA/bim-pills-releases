<Window x:Class="BIMPills.UI.Transfer.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vt="clr-namespace:BIMPills.UI.ViewTemplates"
        xmlns:vf="clr-namespace:BIMPills.UI.ViewFilters"
        xmlns:ps="clr-namespace:BIMPills.UI.ProjectStandards"
        Title="BIM Pills — Importar"
        Width="960" Height="700"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Importar" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ModelNameLabel" Text="Modelo" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>

                        <Button x:Name="FooterTransferButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,0"
                                Margin="8,0,0,0"
                                IsEnabled="False"
                                Click="Transfer_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TransferButtonLabel" Text="Importar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Tab bar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <Border x:Name="Tab1Border" Style="{StaticResource TabHeaderActive}"
                                MouseLeftButtonDown="TabPlantillas_Click">
                            <TextBlock x:Name="Tab1Text" Style="{StaticResource TabHeaderTextActive}"
                                       Text="Plantillas"/>
                        </Border>
                        <Border x:Name="Tab2Border" Style="{StaticResource TabHeader}"
                                MouseLeftButtonDown="TabFiltros_Click">
                            <TextBlock x:Name="Tab2Text" Style="{StaticResource TabHeaderText}"
                                       Text="Filtros"/>
                        </Border>
                        <Border x:Name="Tab3Border" Style="{StaticResource TabHeader}"
                                MouseLeftButtonDown="TabEstandares_Click">
                            <TextBlock x:Name="Tab3Text" Style="{StaticResource TabHeaderText}"
                                       Text="Otros Est&#225;ndares"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ToolHeaderIconBorder" Width="30" Height="30" CornerRadius="7"
                                Background="#E3F2FD" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ToolHeaderIcon" Text="&#xE8A1;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ToolHeaderTitle" Text="Plantillas de Vista"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="ToolHeaderSubtitle"
                                       Text="Importa plantillas de vista desde otros proyectos abiertos"
                                       FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Content area -->
                <Grid>

                    <!-- Plantillas (tab 0) -->
                    <vt:ViewTemplateTransferPanel x:Name="TemplatesPanel"/>

                    <!-- Filtros (tab 1) -->
                    <vf:ViewFilterTransferPanel x:Name="FiltersPanel" Visibility="Collapsed"/>

                    <!-- Otros Estándares (tab 2) -->
                    <ps:ProjectStandardsTransferPanel x:Name="StandardsPanel" Visibility="Collapsed"/>

                    <!-- Loading overlay -->
                    <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Panel.ZIndex="10">
                        <Border Background="#CCFFFFFF"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True"
                                         Width="200" Height="3" Margin="0,0,0,14"
                                         Foreground="{StaticResource AccentBrush}"
                                         Background="#E5E5EA" BorderThickness="0"/>
                            <TextBlock x:Name="LoadingText"
                                       Text="Cargando..."
                                       FontSize="13" FontWeight="Medium"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </Grid>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
