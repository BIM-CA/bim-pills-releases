<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════
         BIM Pills — Iconos vectoriales 32x32
         ══════════════════════════════════════════════ -->

    <!-- Icono de Auditoría: lupa sobre documento con checklist -->
    <DrawingImage x:Key="AuditIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Documento -->
                <GeometryDrawing Brush="#212B37">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 6,2 L 20,2 L 24,6 L 24,28 C 24,29.1 23.1,30 22,30 L 8,30 C 6.9,30 6,29.1 6,28 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Esquina doblada del documento -->
                <GeometryDrawing Brush="#2D3A49">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 20,2 L 20,6 L 24,6 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Lineas de checklist -->
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="9,10,10,1.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="9,15,10,1.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="9,20,7,1.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Lupa: circulo -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#EF6337" Thickness="2.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="23,21" RadiusX="6" RadiusY="6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Lupa: mango -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#EF6337" Thickness="2.5" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="27.2,25.2" EndPoint="31,29"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- Icono Acerca de: circulo con "i" de informacion -->
    <DrawingImage x:Key="AboutIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Circulo de fondo -->
                <GeometryDrawing Brush="#FECA29">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="14" RadiusY="14"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Punto de la "i" -->
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,9" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Cuerpo de la "i" -->
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="14,13.5,4,12" RadiusX="1" RadiusY="1"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- Icono de Píldora BIM Pills: cápsula half-white half-orange -->
    <DrawingImage x:Key="PillIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Mitad superior de la cápsula — blanca -->
                <GeometryDrawing Brush="#FFFFFF">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 10,16 L 10,8 C 10,3.58 13.58,0 18,0 L 18,0 C 22.42,0 26,3.58 26,8 L 26,16 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Mitad inferior de la cápsula — naranja/coral BIM-CA -->
                <GeometryDrawing Brush="#EF6337">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 10,16 L 26,16 L 26,24 C 26,28.42 22.42,32 18,32 L 18,32 C 13.58,32 10,28.42 10,24 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Contorno de la cápsula completa -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#212B37" Thickness="1.2"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 10,8 C 10,3.58 13.58,0 18,0 C 22.42,0 26,3.58 26,8 L 26,24 C 26,28.42 22.42,32 18,32 C 13.58,32 10,28.42 10,24 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Línea divisoria central -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#212B37" Thickness="0.8"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="10,16" EndPoint="26,16"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Reflejo brillante en la mitad superior -->
                <GeometryDrawing Brush="#20FFFFFF">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 13,4 C 14,2.5 15.5,1.5 18,1.5 C 16,1.5 14.5,3 13.5,5 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
