<Window x:Class="BIMPills.UI.Shared.BimPillsProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
        Title="BIM Pills"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Drop shadow wrapper -->
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="12"
            BorderBrush="#E5E5EA"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.18"
                              BlurRadius="22"
                              ShadowDepth="3"
                              Direction="270"/>
        </Border.Effect>

        <DockPanel>

            <!-- Title bar (drag area) -->
            <Border x:Name="TitleBar"
                    DockPanel.Dock="Top"
                    Background="Transparent"
                    CornerRadius="12,12,0,0"
                    Height="40"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               x:Name="WindowTitleText"
                               Text="BIM Pills — Procesando"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Footer with cancel button -->
            <Border DockPanel.Dock="Bottom"
                    Background="#FAFAFA"
                    CornerRadius="0,0,12,12"
                    BorderBrush="#EEEEEE"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <DockPanel>
                    <TextBlock x:Name="ElapsedText"
                               DockPanel.Dock="Left"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Text=""/>
                    <Button x:Name="CancelButton"
                            DockPanel.Dock="Right"
                            Content="Cancelar"
                            MinWidth="100" Height="34"
                            Padding="16,0"
                            HorizontalAlignment="Right"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"
                            Style="{StaticResource SecondaryButton}"
                            Click="CancelButton_Click"/>
                </DockPanel>
            </Border>

            <!-- Content area -->
            <Grid Margin="28,4,28,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon container: pill logo + spinning badge overlay -->
                <Grid Grid.Column="0"
                      Width="56" Height="72"
                      VerticalAlignment="Top"
                      Margin="0,4,18,0">
                    <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                           Width="44" Height="70"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Spinning activity badge — sin fondo azul, el ícono ya trae color -->
                    <Border x:Name="StatusBadge"
                            Width="36" Height="36"
                            Background="Transparent"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,-6,-4">
                        <!-- Rotating icon (sync / progress ring) -->
                        <bimca:Icon x:Name="StatusBadgeIcon"
                                    Slug="settings" Size="32"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                            <bimca:Icon.RenderTransform>
                                <RotateTransform x:Name="BadgeRotation" Angle="0"/>
                            </bimca:Icon.RenderTransform>
                            <bimca:Icon.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="BadgeRotation"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:1.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </bimca:Icon.Triggers>
                        </bimca:Icon>
                    </Border>
                </Grid>

                <!-- Text + progress -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock x:Name="HeaderText"
                               Text="Procesando…"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               Margin="0,6,0,6"/>

                    <TextBlock x:Name="MessageText"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               LineHeight="19"
                               Text="Preparando…"/>

                    <!-- Progress bar -->
                    <Border Background="#EFEFF4"
                            CornerRadius="4"
                            Height="8"
                            Margin="0,14,0,0">
                        <Border x:Name="ProgressFill"
                                HorizontalAlignment="Left"
                                Width="0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="4"/>
                    </Border>

                    <!-- Counter + detail (current item) -->
                    <DockPanel Margin="0,10,0,0">
                        <TextBlock x:Name="CounterText"
                                   DockPanel.Dock="Right"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Segoe UI"
                                   Text="0 / 0"/>
                        <TextBlock x:Name="DetailText"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI"
                                   TextTrimming="CharacterEllipsis"
                                   Text=""/>
                    </DockPanel>
                </StackPanel>
            </Grid>

        </DockPanel>
    </Border>
</Window>
