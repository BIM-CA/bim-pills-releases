<UserControl x:Class="BIMPills.UI.Keynotes.KeynotesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BIMPills.UI.Keynotes"
             xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:LevelToMarginConverter x:Key="LevelToMargin"/>
            <local:BoolToFolderIconConverter x:Key="BoolToFolderIcon"/>
            <local:BoolToFolderColorConverter x:Key="BoolToFolderColor"/>
            <local:BoolToExpandIconConverter x:Key="BoolToExpandIcon"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

    <!-- ══ Layer 1: Main panel content ══ -->
    <DockPanel>

        <!-- File path bar -->
        <Border DockPanel.Dock="Top"
                Background="#F8F9FA" Padding="14,9"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Archivo:" FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Recargar" Style="{StaticResource TertiaryButton}"
                        Height="26" Padding="10,0" Margin="6,0,0,0"
                        Click="ReloadFile_Click"/>
                <Button DockPanel.Dock="Right"
                        Content="Examinar..." Style="{StaticResource TertiaryButton}"
                        Height="26" Padding="10,0" Margin="6,0,0,0"
                        Click="BrowseFile_Click"/>
                <TextBox x:Name="FilePathBox"
                         IsReadOnly="True" Height="26"
                         FontFamily="Segoe UI" FontSize="11"
                         Background="White" BorderBrush="#D1D1D6" BorderThickness="1"
                         Padding="8,4" VerticalContentAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                Padding="14,8">
            <DockPanel>
                <!-- Right: save + data actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="AddFolderButton"
                            Style="{StaticResource TertiaryButton}"
                            Height="28" Padding="10,0" Click="AddFolder_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <bimca:Icon Slug="upload-arrow" Size="13"
                                        Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Carpeta" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddKeynoteButton"
                            Style="{StaticResource TertiaryButton}"
                            Height="28" Padding="10,0" Margin="6,0,0,0"
                            Click="AddKeynote_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <bimca:Icon Slug="pageright" Size="13"
                                        Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Nota clave" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DeleteRowButton" Content="&#x2212;  Eliminar"
                            Style="{StaticResource TertiaryButton}"
                            Height="28" Padding="10,0" Margin="6,0,0,0"
                            IsEnabled="False" Click="DeleteRow_Click"/>
                    <Rectangle Width="1" Fill="#E5E5EA" Margin="10,4"/>
                    <Button Content="&#x2191;  Importar Excel" Style="{StaticResource TertiaryButton}"
                            Height="28" Padding="10,0" Click="ImportExcel_Click"/>
                    <Button Content="&#x2193;  Exportar Excel" Style="{StaticResource TertiaryButton}"
                            Height="28" Padding="10,0" Margin="6,0,0,0" Click="ExportExcel_Click"/>
                    <Rectangle Width="1" Fill="#E5E5EA" Margin="10,4"/>
                    <Button x:Name="SaveTxtButton"
                            Content="&#x1F4BE;  Guardar .txt"
                            Style="{StaticResource PrimaryButton}"
                            Height="28" Padding="14,0"
                            IsEnabled="False" Click="SaveTxt_Click"/>
                </StackPanel>
                <!-- Left: search -->
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource BIMPillsTextBox}"
                         Height="28" MaxWidth="260"
                         FontSize="11" Tag="Buscar nota clave..."
                         TextChanged="Search_TextChanged"/>
            </DockPanel>
        </Border>

        <!-- Legend -->
        <Border DockPanel.Dock="Top"
                Background="#F8F9FA" Padding="14,5"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Drag hint -->
                <TextBlock DockPanel.Dock="Right"
                           Text="&#x2630; Arrastra filas para cambiar jerarqu&#237;a"
                           FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                           VerticalAlignment="Center" FontStyle="Italic"/>
                <StackPanel Orientation="Horizontal">
                    <bimca:Icon Slug="upload-arrow" Size="13"
                                Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Grupo" FontSize="10" Foreground="#86868B"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <bimca:Icon Slug="pageright" Size="13"
                                Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Elemento" FontSize="10" Foreground="#86868B"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Width="10" Height="10" CornerRadius="2"
                            Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1.5" Margin="0,0,4,0"/>
                    <TextBlock Text="Modificado" FontSize="10" Foreground="#86868B"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Width="10" Height="10" CornerRadius="2"
                            Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1.5" Margin="0,0,4,0"/>
                    <TextBlock Text="Nuevo" FontSize="10" Foreground="#86868B"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="14,8">
            <TextBlock x:Name="StatusText" FontSize="11" FontFamily="Segoe UI"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <!-- DataGrid with drag-drop tree -->
        <DataGrid x:Name="KeynotesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="32"
                  BorderThickness="0"
                  AllowDrop="True"
                  SelectionChanged="KeynotesGrid_SelectionChanged"
                  CellEditEnding="KeynotesGrid_CellEditEnding"
                  PreviewMouseLeftButtonDown="KeynotesGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="KeynotesGrid_PreviewMouseMove"
                  DragOver="KeynotesGrid_DragOver"
                  DragLeave="KeynotesGrid_DragLeave"
                  Drop="KeynotesGrid_Drop">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Expandir todo" Click="ExpandAll_Click">
                        <MenuItem.Icon>
                            <bimca:Icon Slug="rotate-sync" Size="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Colapsar todo" Click="CollapseAll_Click">
                        <MenuItem.Icon>
                            <bimca:Icon Slug="refresh" Size="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="Foreground" Value="#86868B"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="BorderBrush" Value="#E5E5EA"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#DBEAFE"/>
                            <Setter Property="Foreground" Value="#1565C0"/>
                        </Trigger>
                        <Trigger Property="IsEditing" Value="True">
                            <Setter Property="Background" Value="#FFFDE7"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- Base: plain white -->
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#F2F2F7"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <!-- Drop target — blue border, overrides all -->
                        <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                            <Setter Property="Background" Value="#DBEAFE"/>
                            <Setter Property="BorderBrush" Value="#1565C0"/>
                            <Setter Property="BorderThickness" Value="0,2,0,2"/>
                        </DataTrigger>
                        <!-- New row -->
                        <DataTrigger Binding="{Binding IsNew}" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </DataTrigger>
                        <!-- Modified -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsModified}"   Value="True"/>
                                <Condition Binding="{Binding IsNew}"        Value="False"/>
                                <Condition Binding="{Binding IsDropTarget}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#EFF6FF"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- Drag handle -->
                <DataGridTemplateColumn Width="28" MinWidth="28" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="&#x2630;" FontSize="13"
                                       Foreground="#C0C0C8" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Cursor="SizeAll" ToolTip="Arrastra para cambiar jerarqu&#237;a"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CLAVE: expand toggle + folder/document icon + indent + key text -->
                <DataGridTemplateColumn Header="CLAVE" Width="200" MinWidth="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel Margin="{Binding Level, Converter={StaticResource LevelToMargin}}">

                                <!-- Expand/collapse chevron — only for groups -->
                                <Border DockPanel.Dock="Left"
                                        Width="18" Height="24" Cursor="Hand"
                                        Background="Transparent"
                                        Visibility="{Binding IsGroup, Converter={StaticResource BoolToVis}}"
                                        MouseLeftButtonDown="ToggleExpand_MouseDown"
                                        ToolTip="Expandir / Colapsar">
                                    <bimca:Icon Slug="{Binding IsExpanded, Converter={StaticResource BoolToExpandIcon}}"
                                                Size="11"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Spacer for non-groups (same width as chevron) -->
                                <Border DockPanel.Dock="Left" Width="18"
                                        Visibility="{Binding IsGroup, Converter={StaticResource InverseBoolToVis}}"/>

                                <!-- Folder / document icon -->
                                <bimca:Icon DockPanel.Dock="Left"
                                            Slug="{Binding IsGroup, Converter={StaticResource BoolToFolderIcon}}"
                                            Size="14"
                                            Margin="0,0,6,0" VerticalAlignment="Center"/>

                                <!-- Key -->
                                <TextBlock Text="{Binding Key}"
                                           FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                           FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Key, UpdateSourceTrigger=LostFocus}"
                                     FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                     FontSize="12" Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="#FFFDE7"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- DESCRIPCIÓN -->
                <DataGridTextColumn Header="DESCRIPCI&#xD3;N"
                                    Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                    Width="*" MinWidth="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="#FFFDE7"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>

    <!-- ══ Layer 2: Empty-state overlay (visible when no file is loaded) ══ -->
    <Border x:Name="EmptyStateOverlay"
            Background="#F8F9FA"
            Visibility="Visible">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">

            <!-- Icon -->
            <Border Width="72" Height="72" CornerRadius="18"
                    Background="#EFF3FF" HorizontalAlignment="Center" Margin="0,0,0,20">
                <bimca:Icon Slug="pageright" Size="36"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Title -->
            <TextBlock x:Name="EmptyStateTitle"
                       Text="Sin archivo de notas clave"
                       FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <!-- Subtitle -->
            <TextBlock x:Name="EmptyStateSubtitle"
                       Text="Para comenzar, genera un nuevo archivo de notas clave o carga uno ya existente."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="Segoe UI" TextWrapping="Wrap"
                       TextAlignment="Center" Margin="0,0,0,28"/>

            <!-- Actions -->
            <Button Content="  Generar nuevo archivo"
                    Style="{StaticResource PrimaryButton}"
                    Height="38" Padding="24,0" HorizontalAlignment="Center"
                    Margin="0,0,0,10" Click="GenerateFile_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <bimca:Icon Slug="add-new" Size="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Generar nuevo archivo" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button Style="{StaticResource SecondaryButton}"
                    Height="38" Padding="24,0" HorizontalAlignment="Center"
                    Click="BrowseFile_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <bimca:Icon Slug="trash" Size="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cargar archivo existente" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

        </StackPanel>
    </Border>

    </Grid>
</UserControl>
