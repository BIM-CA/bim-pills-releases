<Window x:Class="BIMPills.UI.MCPIntegration.MCPConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIMPills.UI.MCPIntegration"
        xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
        Title="BIM Pills — Integración AI"
        Width="500" Height="660"
        MinWidth="440" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png" Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Integración AI" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Claude AI + MCP Personalizado" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Conecta BIMPills con inteligencia artificial"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer — Cerrar left -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>
                    </DockPanel>
                </Border>

                <!-- Tab strip -->
                <TabControl x:Name="MainTabs" Style="{StaticResource BIMPillsTabControl}"
                            DockPanel.Dock="Top">

                    <!-- ══════ Tab 1: Claude AI ══════ -->
                    <TabItem Header="Claude AI" Style="{StaticResource BIMPillsTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,0,0,0">
                            <StackPanel Margin="8,12,8,8">

                                <!-- Status badge -->
                                <Border x:Name="StatusBadge" CornerRadius="6" Padding="12,8" Margin="0,0,0,14"
                                        Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <bimca:Icon x:Name="StatusIcon" Slug="reportwarning" Size="14"
                                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatusText"
                                                   Text="No configurado — ingresa tu API Key para comenzar"
                                                   FontSize="12" Foreground="#E65100" FontFamily="Segoe UI"
                                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- API Key -->
                                <TextBlock Text="API Key de Anthropic" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           Margin="0,0,0,4"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,0,0,6" TextWrapping="Wrap">
                                    Obtén tu API Key en <Run Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold">console.anthropic.com</Run>
                                </TextBlock>
                                <PasswordBox x:Name="ApiKeyBox" Height="34" FontSize="12"
                                             Background="White" BorderBrush="#D1D1D6" BorderThickness="1"
                                             Padding="10,6" FontFamily="Segoe UI"
                                             PasswordChanged="ApiKey_Changed"/>

                                <!-- Model selector -->
                                <TextBlock Text="Modelo" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           Margin="0,12,0,6"/>
                                <ComboBox x:Name="ModelCombo" Style="{StaticResource BIMPillsComboBox}">
                                    <ComboBoxItem Content="claude-sonnet-4-5 (recomendado)" Tag="claude-sonnet-4-5" IsSelected="True"/>
                                    <ComboBoxItem Content="claude-opus-4-5 (avanzado)" Tag="claude-opus-4-5"/>
                                    <ComboBoxItem Content="claude-haiku-4-5 (rápido)" Tag="claude-haiku-4-5"/>
                                </ComboBox>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button x:Name="TestBtn" Content="Probar conexión"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="140" Click="TestConnection_Click"/>
                                    <Button Content="Guardar" Style="{StaticResource PrimaryButton}"
                                            Width="100" Margin="8,0,0,0" Click="Save_Click"/>
                                </StackPanel>

                                <!-- What Claude can do -->
                                <Border Background="#F8F9FA" CornerRadius="6" Padding="12,10" Margin="0,16,0,0"
                                        BorderBrush="#E5E5EA" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Con Claude AI activo, BIMPills puede:"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                                   Text="• Analizar el informe de salud del modelo&#x0A;• Priorizar advertencias y explicar su impacto&#x0A;• Sugerir optimizaciones BIM con contexto del modelo&#x0A;• Generar informes narrativos para el equipo"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ══════ Tab 2: MCP Personalizado ══════ -->
                    <TabItem Header="MCP Personalizado" Style="{StaticResource BIMPillsTabItem}">
                        <DockPanel Margin="8,12,8,8">

                            <!-- Info box -->
                            <Border DockPanel.Dock="Top"
                                    Background="#E3F2FD" CornerRadius="6"
                                    Padding="12,8" Margin="0,0,0,12"
                                    BorderBrush="#90CAF9" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="#0D47A1" FontFamily="Segoe UI"
                                               Margin="0,0,0,2" Text="¿Qué es MCP?"/>
                                    <TextBlock FontSize="11" Foreground="#1565C0"
                                               FontFamily="Segoe UI" TextWrapping="Wrap"
                                               Text="Model Context Protocol permite a la IA acceder a herramientas externas. El servidor MCP de Revit ya está instalado en tu equipo — agrégalo aquí para que la IA pueda consultar el modelo directamente."/>
                                </StackPanel>
                            </Border>

                            <!-- Add connection form (collapsed by default) -->
                            <Border x:Name="McpFormPanel" DockPanel.Dock="Top"
                                    Visibility="Collapsed"
                                    Background="#F5F5F7" CornerRadius="6"
                                    Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="#D0D0D0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Nueva Conexión MCP" FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Nombre:" FontSize="11" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"/>
                                        <TextBox x:Name="McpNameBox" Grid.Column="1"
                                                 Style="{StaticResource BIMPillsTextBox}"
                                                 FontSize="11" Padding="6,4"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Endpoint:" FontSize="11" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"/>
                                        <TextBox x:Name="McpEndpointBox" Grid.Column="1"
                                                 Style="{StaticResource BIMPillsTextBox}"
                                                 FontSize="11" Padding="6,4"
                                                 Text="http://localhost:3000"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancelar" Style="{StaticResource TertiaryButton}"
                                                Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                                Click="CancelMcp_Click"/>
                                        <Button Content="Agregar" Style="{StaticResource PrimaryButton}"
                                                Padding="10,4" FontSize="11"
                                                Click="AddMcp_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Toolbar: Nueva + test + delete -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                        Margin="0,8,0,0">
                                <Button Content="+ Nueva conexión" Style="{StaticResource SecondaryButton}"
                                        Padding="12,5" FontSize="11"
                                        Click="NewMcpConnection_Click"/>
                                <Button x:Name="TestMcpBtn" Content="Probar"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,5" FontSize="11"
                                        Margin="6,0,0,0" IsEnabled="False"
                                        Click="TestMcpConnection_Click"/>
                                <Button x:Name="DeleteMcpBtn" Content="Eliminar"
                                        Style="{StaticResource TertiaryButton}"
                                        Padding="12,5" FontSize="11"
                                        Margin="6,0,0,0" IsEnabled="False"
                                        Click="DeleteMcpConnection_Click"/>
                            </StackPanel>

                            <!-- Connections list -->
                            <Border BorderBrush="#E5E5EA" BorderThickness="1"
                                    CornerRadius="6" Background="White">
                                <ListBox x:Name="McpConnectionsList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontFamily="Segoe UI" FontSize="12"
                                         SelectionChanged="McpConnections_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F0F5FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Endpoint}" FontSize="10"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4"
                                                        Padding="6,2" VerticalAlignment="Center"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                                               Foreground="White" FontFamily="Segoe UI"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                        </DockPanel>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Border>

    </DockPanel>
</Window>
