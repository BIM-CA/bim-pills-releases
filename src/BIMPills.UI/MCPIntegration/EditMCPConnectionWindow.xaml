<Window x:Class="BIMPills.UI.MCPIntegration.EditMCPConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIMPills.UI.MCPIntegration"
        Title="BIM Pills — Editar Conexión MCP"
        Width="700" Height="650"
        MinWidth="600" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Editar Conexión MCP"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,16"
                   FontFamily="Segoe UI"/>

        <!-- Content -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,12">

                    <!-- Name field -->
                    <TextBlock Text="Nombre de la Conexión" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameTextBox" Style="{StaticResource BIMPillsTextBox}"
                             Margin="0,0,0,14" MinHeight="36"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                    <!-- Description field -->
                    <TextBlock Text="Descripción" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="DescriptionTextBox" Style="{StaticResource BIMPillsTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="60" MaxHeight="100"
                             Margin="0,0,0,14"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                    <!-- Endpoint field -->
                    <TextBlock Text="Endpoint (URL o Ruta Local)" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EndpointTextBox" Style="{StaticResource BIMPillsTextBox}"
                             Margin="0,0,0,14" MinHeight="36"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                    <!-- Credentials section -->
                    <TextBlock Text="Credenciales (API Key, Token, etc.)" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <ListBox x:Name="CredentialsList" MinHeight="100" MaxHeight="200"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Margin="0,0,0,14">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="••••••••" FontSize="11" Foreground="#86868B"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- API Key field (example credential) -->
                    <TextBlock Text="API Key (Ejemplo)" FontSize="11" FontStyle="Italic"
                               Foreground="#86868B" Margin="0,0,0,6"/>
                    <TextBox x:Name="ApiKeyTextBox" Style="{StaticResource BIMPillsTextBox}"
                             Margin="0,0,0,14" MinHeight="36"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Guardar"
                        Style="{StaticResource PrimaryButton}"
                        Width="100"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>

    </DockPanel>
</Window>
