<Window x:Class="BIMPills.UI.ExportFamilies.ExportarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIMPills.UI.ExportFamilies"
        xmlns:sheets="clr-namespace:BIMPills.UI.ExportSheets"
        xmlns:model="clr-namespace:BIMPills.UI.ExportModel"
        Title="BIM Pills — Exportar"
        Width="880" Height="720"
        MinWidth="700" MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32" Margin="0,0,12,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel>
                    <TextBlock Text="Exportar"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="DocumentName"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="Herramientas de exportación de datos"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Tab bar — estilo global folder -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <Border x:Name="TabPlanosBorder" Style="{StaticResource TabHeaderActive}"
                                MouseLeftButtonDown="TabPlanos_Click">
                            <TextBlock x:Name="TabPlanosText" Style="{StaticResource TabHeaderTextActive}"
                                       Text="Planos y Vistas"/>
                        </Border>
                        <Border x:Name="TabModeloBorder" Style="{StaticResource TabHeader}"
                                MouseLeftButtonDown="TabModelo_Click">
                            <TextBlock x:Name="TabModeloText" Style="{StaticResource TabHeaderText}"
                                       Text="Modelo"/>
                        </Border>
                        <Border x:Name="TabFamiliasBorder" Style="{StaticResource TabHeader}"
                                MouseLeftButtonDown="TabFamilias_Click">
                            <TextBlock x:Name="TabFamiliasText" Style="{StaticResource TabHeaderText}"
                                       Text="Familias"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="7" Background="#E3F2FD"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ToolHeaderIcon" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ToolHeaderTitle" Text="Exportar Planos y Vistas" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="ToolHeaderSubtitle" Text="Exporta planos y vistas a PDF y DWG en lote"
                                       FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Footer — Cerrar left, action buttons right -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#E5E5EA" BorderThickness="0,1,0,0" Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>

                        <Button x:Name="ActionButton"
                                DockPanel.Dock="Right"
                                Content="Exportar"
                                Style="{StaticResource SecondaryButton}"
                                Padding="18,0"
                                IsEnabled="False"
                                Click="Action_Click"/>
                    </DockPanel>
                </Border>

                <!-- Content panels -->
                <Grid>
                    <sheets:ExportSheetsPanel x:Name="SheetsPanel"/>
                    <model:ExportModelPanel x:Name="ModelPanel" Visibility="Collapsed"/>
                    <local:ExportFamiliesPanel x:Name="ExportPanel" Visibility="Collapsed"/>
                </Grid>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
