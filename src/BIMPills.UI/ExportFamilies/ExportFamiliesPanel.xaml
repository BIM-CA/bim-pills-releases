<UserControl x:Class="BIMPills.UI.ExportFamilies.ExportFamiliesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para boton primario azul oscuro (exportar) -->
            <Style x:Key="DarkPrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#212B37"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="20,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3A4A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1A2230"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#A0A0A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Summary bar -->
        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SummaryText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="{DynamicResource PrimaryBrush}"/>

                <Button x:Name="SelectAllButton"
                        Grid.Column="1"
                        Content="Seleccionar todo"
                        Style="{DynamicResource TertiaryButton}"
                        Padding="12,5"
                        FontSize="12"
                        Margin="8,0,8,0"
                        Click="SelectAll_Click"/>

                <TextBlock x:Name="SelectionText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
        </Border>

        <!-- Main content - DataGrid -->
        <Grid Grid.Row="1" Margin="12,0,12,8">
            <DataGrid x:Name="FamiliesGrid"
                      Style="{DynamicResource BIMPillsDataGrid}"
                      IsReadOnly="False"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Click="FamilyCheckBox_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Nombre"    Binding="{Binding Name}"     Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="180" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock x:Name="ExportScrollUpHint"
                       Text="&#x25B2; más familias arriba"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                       Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                       IsHitTestVisible="False" Visibility="Collapsed"/>
            <TextBlock x:Name="ExportScrollDownHint"
                       Text="&#x25BC; más familias abajo"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                       Background="#EEFFFFFF" Padding="12,3"
                       IsHitTestVisible="False" Visibility="Collapsed"/>
        </Grid>

        <!-- Destination bar -->
        <Border Grid.Row="2" Margin="12,0,12,8"
                Background="{DynamicResource AlternateRowBrush}"
                CornerRadius="8"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="1"
                Padding="14,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Destino:"
                               VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,10,0"/>

                    <TextBox x:Name="DestinationPath"
                             Grid.Column="1"
                             IsReadOnly="True"
                             VerticalAlignment="Center"
                             FontSize="12" FontFamily="Segoe UI"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             Background="White"
                             BorderBrush="{DynamicResource SeparatorBrush}"
                             BorderThickness="1"
                             Padding="8,6"
                             Text="Seleccionar carpeta..."
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            Content="Examinar..."
                            Style="{DynamicResource TertiaryButton}"
                            Padding="14,5"
                            FontSize="12"
                            Click="Browse_Click"/>
                </Grid>

                <!-- Version suffix option -->
                <StackPanel Margin="0,8,0,0">
                    <CheckBox x:Name="VersionSuffixCheck"
                              FontSize="12" FontFamily="Segoe UI"
                              Foreground="{DynamicResource PrimaryBrush}"
                              Checked="VersionSuffixCheck_Changed"
                              Unchecked="VersionSuffixCheck_Changed">
                        <TextBlock x:Name="VersionSuffixLabel"
                                   Text="Agregar sufijo de versión al nombre de la familia"
                                   FontSize="12" FontFamily="Segoe UI"/>
                    </CheckBox>
                    <Border x:Name="VersionSuffixInfo"
                            Visibility="Collapsed"
                            Background="#F0F4FF"
                            BorderBrush="#BBDEFB"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="20,6,0,0">
                        <TextBlock x:Name="VersionSuffixInfoText"
                                   TextWrapping="Wrap"
                                   FontSize="11" FontFamily="Segoe UI"
                                   Foreground="#1565C0"/>
                    </Border>
                </StackPanel>

                <!-- Folder structure preview (collapsible) -->
                <Expander IsExpanded="False" Margin="0,8,0,0">
                    <Expander.Header>
                        <TextBlock Text="ESTRUCTURA DE CARPETAS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                    </Expander.Header>
                    <Border Background="White"
                            BorderBrush="{DynamicResource SeparatorBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,4,0,0">
                        <TextBlock x:Name="FolderPreviewText"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="#3C3C43"
                                   LineHeight="18"/>
                    </Border>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Footer removed — buttons moved to ExportarWindow footer -->

        <!-- Progress overlay -->
        <Grid x:Name="ProgressOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              Visibility="Collapsed">
            <Border Background="#CC000000">
                <Border Background="White" CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="40,30"
                        MinWidth="350">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ProgressText"
                                   Text="Exportando..."
                                   FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <ProgressBar x:Name="ProgressBar"
                                     Width="280" Height="8"
                                     Minimum="0" Maximum="100"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource SeparatorBrush}"/>
                        <TextBlock x:Name="ProgressDetail"
                                   Text=""
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
