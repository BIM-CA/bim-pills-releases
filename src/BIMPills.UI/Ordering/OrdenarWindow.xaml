<Window x:Class="BIMPills.UI.Ordering.OrdenarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Ordenar"
        Width="480" SizeToContent="Height"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Círculo numerado de paso -->
            <Style x:Key="StepCircle" TargetType="Border">
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>

            <!-- Chip de selección de tipo — igual que ScopeChip de Documentar -->
            <Style x:Key="TypeChip" TargetType="Border">
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="16,14,16,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="18" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Ordenar" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Numerador" FontSize="14" FontWeight="Bold"
                               Foreground="#1A1A2E" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Tab bar — estilo global folder -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <Border x:Name="Tab1Border" Style="{StaticResource TabHeaderActive}">
                            <TextBlock x:Name="Tab1Text" Style="{StaticResource TabHeaderTextActive}"
                                       Text="Numerador"/>
                        </Border>
                        <Border Padding="12,9,12,8">
                            <TextBlock Text="Pronto..." FontSize="12" FontStyle="Italic"
                                       Foreground="#C7C7CC" FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="7" Background="#E3F2FD"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xEA42;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Numerador" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock Text="Asigna valores incrementales a elementos del modelo"
                                       FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cancelar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Cancel_Click"/>
                        <Button x:Name="IniciarButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Padding="18,0"
                                Click="Iniciar_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x25B6;" FontSize="9" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Iniciar" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Contenido de pasos (con scroll) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,14,16,14">

                        <!-- PASO 1: Tipo de categoría -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource StepCircle}">
                                    <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Tipo de categoría" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="¿Qué tipo de elementos deseas numerar?"
                                       FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                       Margin="34,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="34,0,0,0">
                                <Border x:Name="ModeloChip" Style="{StaticResource TypeChip}"
                                        Background="#FFF0EBE6" BorderBrush="{StaticResource AccentBrush}"
                                        MouseLeftButtonDown="TypeChip_Click" Tag="Modelo">
                                    <TextBlock Text="Modelo" FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{StaticResource AccentBrush}" FontWeight="Medium"/>
                                </Border>
                                <Border x:Name="AnotacionChip" Style="{StaticResource TypeChip}"
                                        MouseLeftButtonDown="TypeChip_Click" Tag="Anotacion">
                                    <TextBlock x:Name="AnotacionChipText"
                                               Text="Anotación" FontSize="12" FontFamily="Segoe UI"
                                               Foreground="#86868B"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- PASO 2: Categoría -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource StepCircle}">
                                    <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Categoría" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Filtra los elementos que se pueden seleccionar en la vista."
                                       FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                       Margin="34,0,0,8"/>
                            <ComboBox x:Name="CategoryCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Margin="34,0,0,0"
                                      SelectionChanged="CategoryCombo_SelectionChanged"/>
                        </StackPanel>

                        <!-- PASO 3: Parámetro -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource StepCircle}">
                                    <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Parámetro a escribir" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="El valor incremental se escribirá en este parámetro."
                                       FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                       Margin="34,0,0,8"/>
                            <ComboBox x:Name="ParameterCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Margin="34,0,0,0"
                                      IsEditable="True"
                                      SelectionChanged="UpdatePreview"/>
                        </StackPanel>

                        <!-- PASO 4: Configurar valor -->
                        <StackPanel Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource StepCircle}">
                                    <TextBlock Text="4" Foreground="White" FontSize="11" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Configurar valor" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Define el tipo de secuencia, prefijo, valor de inicio, paso y sufijo."
                                       FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                       Margin="34,0,0,8"/>

                            <!-- Tipo de secuencia: Numérico / Alfabético -->
                            <StackPanel Orientation="Horizontal" Margin="34,0,0,12">
                                <Border x:Name="NumericChip" Style="{StaticResource TypeChip}"
                                        Background="#FFF0EBE6" BorderBrush="{StaticResource AccentBrush}"
                                        MouseLeftButtonDown="SeqTypeChip_Click" Tag="Numeric">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="NumericChipBold" Text="123"
                                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="NumericChipText" Text="Numérico"
                                                   FontSize="12" FontFamily="Segoe UI"
                                                   Foreground="{StaticResource AccentBrush}" FontWeight="Medium"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="AlphabeticChip" Style="{StaticResource TypeChip}"
                                        MouseLeftButtonDown="SeqTypeChip_Click" Tag="Alphabetic">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="AlphabeticChipBold" Text="ABC"
                                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                                   Foreground="#86868B"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AlphabeticChipText" Text="Alfabético"
                                                   FontSize="12" FontFamily="Segoe UI"
                                                   Foreground="#86868B"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Prefijo / Inicio / Paso / Sufijo -->
                            <Grid Margin="34,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="0" Text="Prefijo"
                                           FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"/>
                                <TextBlock Grid.Column="2" Grid.Row="0" Text="Inicio"
                                           FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Grid.Row="0" Text="Paso"
                                           FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Grid.Row="0" Text="Sufijo"
                                           FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"/>

                                <TextBox x:Name="PrefixBox" Grid.Column="0" Grid.Row="2"
                                         Height="34" FontFamily="Segoe UI" FontSize="13"
                                         Padding="8,0" Background="White"
                                         BorderBrush="#D1D1D6" BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         TextChanged="UpdatePreview"/>
                                <TextBox x:Name="StartBox" Grid.Column="2" Grid.Row="2"
                                         Height="34" FontFamily="Segoe UI" FontSize="13"
                                         Text="1" Padding="8,0" Background="White"
                                         BorderBrush="#D1D1D6" BorderThickness="1"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextChanged="UpdatePreview"/>
                                <TextBox x:Name="StepBox" Grid.Column="4" Grid.Row="2"
                                         Height="34" FontFamily="Segoe UI" FontSize="13"
                                         Text="1" Padding="8,0" Background="White"
                                         BorderBrush="#D1D1D6" BorderThickness="1"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextChanged="UpdatePreview"/>
                                <TextBox x:Name="SuffixBox" Grid.Column="6" Grid.Row="2"
                                         Height="34" FontFamily="Segoe UI" FontSize="13"
                                         Padding="8,0" Background="White"
                                         BorderBrush="#D1D1D6" BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         TextChanged="UpdatePreview"/>
                            </Grid>

                            <!-- Vista previa de valores (pills) -->
                            <Border Background="#F7F7F9" CornerRadius="8" Padding="12,10" Margin="34,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="VISTA PREVIA DE VALORES"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#86868B" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <!-- Pill 1 — activa -->
                                        <Border BorderBrush="#1A1A2E" BorderThickness="1.5"
                                                CornerRadius="6" Background="#F5F5F7"
                                                Padding="12,5" MinWidth="52">
                                            <TextBlock x:Name="Pill1" Text="1"
                                                       FontFamily="Consolas" FontSize="13"
                                                       FontWeight="Bold" Foreground="#1A1A2E"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="→" FontSize="11" Foreground="#C7C7CC"
                                                   VerticalAlignment="Center" Margin="6,0"/>

                                        <!-- Pill 2 -->
                                        <Border BorderBrush="#D1D1D6" BorderThickness="1.5"
                                                CornerRadius="6" Background="White"
                                                Padding="12,5" MinWidth="52">
                                            <TextBlock x:Name="Pill2" Text="2"
                                                       FontFamily="Consolas" FontSize="13"
                                                       FontWeight="Bold" Foreground="#1A1A2E"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="→" FontSize="11" Foreground="#C7C7CC"
                                                   VerticalAlignment="Center" Margin="6,0"/>

                                        <!-- Pill 3 -->
                                        <Border BorderBrush="#D1D1D6" BorderThickness="1.5"
                                                CornerRadius="6" Background="White"
                                                Padding="12,5" MinWidth="52">
                                            <TextBlock x:Name="Pill3" Text="3"
                                                       FontFamily="Consolas" FontSize="13"
                                                       FontWeight="Bold" Foreground="#1A1A2E"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="→" FontSize="11" Foreground="#C7C7CC"
                                                   VerticalAlignment="Center" Margin="6,0"/>

                                        <!-- Pill 4 — atenuada -->
                                        <Border BorderBrush="#EBEBEB" BorderThickness="1.5"
                                                CornerRadius="6" Background="#FAFAFA"
                                                Padding="12,5" MinWidth="52">
                                            <TextBlock x:Name="Pill4" Text="4"
                                                       FontFamily="Consolas" FontSize="13"
                                                       FontWeight="Bold" Foreground="#C7C7CC"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
