<Window x:Class="BIMPills.UI.Ordering.OrdenarSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Ordenar"
        Width="300" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        Background="White"
        WindowStyle="ToolWindow"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel>

        <!-- Orange header -->
        <Border Background="#EF6337" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="HeaderRoute"
                               Text="ORDENAR · Categoría → Parámetro"
                               FontSize="10" Foreground="#BFFFFFFF"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Sesión activa"
                               FontSize="12" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI"/>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="4"
                        Background="#33FFFFFF"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        MouseLeftButtonDown="CloseHeader_Click">
                    <TextBlock Text="✕" FontSize="11" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- SIGUIENTE VALOR -->
        <Border BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="14,14,14,12">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="SIGUIENTE VALOR"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#86868B" FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="NextValueLabel"
                           Text="—"
                           FontSize="38" FontWeight="ExtraBold"
                           Foreground="#1A1A2E"
                           FontFamily="Consolas, Segoe UI"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Stats row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock x:Name="CountLabel" Text="0"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                <TextBlock Text="ASIGNADOS"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#86868B" HorizontalAlignment="Center"
                           FontFamily="Segoe UI"                           Margin="0,2,0,0"/>
            </StackPanel>

            <Rectangle Grid.Column="1" Fill="#E5E5EA" Width="1"/>

            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock x:Name="FirstValueLabel" Text="—"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Consolas, Segoe UI"/>
                <TextBlock Text="PRIMERO"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#86868B" HorizontalAlignment="Center"
                           FontFamily="Segoe UI"                           Margin="0,2,0,0"/>
            </StackPanel>

            <Rectangle Grid.Column="3" Fill="#E5E5EA" Width="1"/>

            <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock x:Name="LastValueLabel" Text="—"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Consolas, Segoe UI"/>
                <TextBlock Text="ÚLTIMO"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="#86868B" HorizontalAlignment="Center"
                           FontFamily="Segoe UI"                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Rectangle Height="1" Fill="#E5E5EA"/>

        <!-- Action buttons -->
        <StackPanel Margin="10,10,10,10">

            <!-- Seleccionar -->
            <Button x:Name="PickButton"
                    Height="36" Margin="0,0,0,5"
                    Style="{StaticResource PrimaryButton}"
                    Click="Pick_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="↑" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Seleccionar siguiente elemento" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <!-- Auto-continue option -->
            <CheckBox x:Name="AutoContinueCheck"
                      Content="Continuar automáticamente"
                      FontSize="11" FontFamily="Segoe UI"
                      Foreground="#86868B" Margin="4,0,0,7"
                      IsChecked="False"/>

            <!-- Deshacer + Finalizar -->
            <Grid Margin="0,0,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="7"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="UndoButton" Grid.Column="0"
                        Height="34" IsEnabled="False"
                        Style="{StaticResource SecondaryButton}"
                        Click="Undo_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↶" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Deshacer" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button x:Name="FinishButton" Grid.Column="2"
                        Height="34"
                        Click="Finish_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                            <Setter Property="Background" Value="#E8F5E9"/>
                            <Setter Property="BorderBrush" Value="#C8E6C9"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Finalizar" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Cancelar -->
            <Button x:Name="CancelButton"
                    Height="34"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                        <Setter Property="Background" Value="#FFF5F5"/>
                        <Setter Property="BorderBrush" Value="#FFCDD2"/>
                        <Setter Property="Foreground" Value="#C62828"/>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✕" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancelar (deshace todos los cambios)" FontSize="11"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Height="1" Fill="#E5E5EA"/>

        <!-- History -->
        <StackPanel Margin="12,10,12,12">
            <TextBlock Text="HISTORIAL"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#86868B" FontFamily="Segoe UI"
                       Margin="0,0,0,8"/>
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#F2F2F7" BorderThickness="0,0,0,1" Padding="0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AssignedValue}"
                                           FontFamily="Consolas" FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementIdDisplay}"
                                           FontSize="11" Foreground="#86868B"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#E8F5E9"
                                        CornerRadius="4" Padding="7,2">
                                    <TextBlock Text="Asignado" FontSize="10"
                                               FontWeight="SemiBold" Foreground="#2E7D32"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="EmptyHistoryLabel"
                       Text="Sin asignaciones aún"
                       FontSize="11" Foreground="#C7C7CC"
                       FontFamily="Segoe UI" FontStyle="Italic"
                       Visibility="Visible"/>
        </StackPanel>

    </StackPanel>
</Window>

