<Window x:Class="BIMPills.UI.Gestion.BimCaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
        Title="BIM Pills — Estándar BIM-CA"
        Width="640" Height="680"
        MinWidth="560" MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <DockPanel Margin="4,0">
                <Image DockPanel.Dock="Left"
                       Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Estandarizar" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Estándar BIM-CA" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120" IsCancel="True"
                                Click="Close_Click"/>
                        <Button x:Name="BtnCreate"
                                DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,0"
                                IsEnabled="False"
                                Click="CreateSelectedWorksets_Click">
                            <StackPanel Orientation="Horizontal">
                                <bimca:Icon Slug="person" Size="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CreateBtnLabel" Text="Crear seleccionados"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Info bar -->
                <Border DockPanel.Dock="Top"
                        Background="#E3F2FD" Padding="14,9"
                        BorderBrush="#90CAF9" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <bimca:Icon DockPanel.Dock="Left" Slug="search-zoom" Size="14"
                                    Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                       Foreground="#0D47A1" FontFamily="Segoe UI"
                                       Text="Estándar BIM-CA"/>
                            <TextBlock FontSize="11" Foreground="#1565C0" FontFamily="Segoe UI"
                                       TextWrapping="Wrap"
                                       Text="Selecciona las disciplinas y subproyectos que deseas crear en el modelo según el estándar BIM-CA."/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Toolbar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#F2F2F7" BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Seleccionar todo"
                                Style="{StaticResource TertiaryButton}"
                                Height="28" FontSize="11" Padding="12,0"
                                Click="SelectAll_Click"/>
                        <Button DockPanel.Dock="Left"
                                Content="Deseleccionar todo"
                                Style="{StaticResource TertiaryButton}"
                                Height="28" FontSize="11" Padding="12,0" Margin="6,0,0,0"
                                Click="DeselectAll_Click"/>
                        <Button DockPanel.Dock="Left"
                                Content="Cargar .txt..."
                                Style="{StaticResource TertiaryButton}"
                                Height="28" FontSize="11" Padding="12,0" Margin="6,0,0,0"
                                Click="LoadCustomTemplate_Click"/>
                        <TextBlock x:Name="SelectionCountText"
                                   DockPanel.Dock="Right"
                                   FontSize="11" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Segoe UI" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Scrollable discipline groups -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,4,14,10">
                    <StackPanel x:Name="TemplateGroupsPanel"/>
                </ScrollViewer>

            </DockPanel>
        </Border>
    </DockPanel>
</Window>
