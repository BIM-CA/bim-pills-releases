<Window x:Class="BIMPills.UI.Gestion.GestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Estandarizar"
        Width="780" Height="620"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Estandarizar"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TitleText"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SubtitleText"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Tab bar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <Border Style="{StaticResource TabHeaderActive}">
                            <TextBlock Style="{StaticResource TabHeaderTextActive}" Text="Subproyectos"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120" IsCancel="True"
                                Click="CloseButton_Click"/>
                        <TextBlock x:Name="WorksetCountText"
                                   DockPanel.Dock="Left"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontFamily="Segoe UI"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Importar Excel"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="14,0" Margin="0,0,8,0"
                                    Click="ImportExcel_Click"/>
                            <Button Content="Exportar Excel"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="14,0"
                                    Click="ExportExcel_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Worksharing notice -->
                <Border x:Name="WorksharingNotice" DockPanel.Dock="Top"
                        Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1"
                        Padding="14,7">
                    <TextBlock FontSize="11" Foreground="#2E7D32" FontFamily="Segoe UI">
                        <Run Text="&#x2714;"/> Worksharing habilitado — Los cambios se sincronizarán al guardar
                    </TextBlock>
                </Border>

                <Border x:Name="NoWorksharingNotice" DockPanel.Dock="Top"
                        Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="0,0,0,1"
                        Padding="14,7" Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#E65100" FontFamily="Segoe UI">
                        <Run Text="&#x26A0;"/> Este modelo no tiene Worksharing habilitado. Los subproyectos no están disponibles.
                    </TextBlock>
                </Border>

                <!-- Toolbar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#F2F2F7" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel LastChildFill="False">
                        <Button x:Name="BtnNewWorkset"
                                DockPanel.Dock="Left"
                                Content="+ Nuevo subproyecto"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,0"
                                Click="NewWorkset_Click"/>
                        <Button DockPanel.Dock="Left"
                                Content="Estándar BIM-CA..."
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,0" Margin="8,0,0,0"
                                Click="BimCa_Click"/>
                        <Button x:Name="BtnCreateViews3D"
                                DockPanel.Dock="Left"
                                Content="Crear Vistas 3D"
                                Style="{StaticResource TertiaryButton}"
                                Padding="12,0" Margin="8,0,0,0"
                                IsEnabled="False"
                                Click="CreateViews3D_Click"/>
                        <Button DockPanel.Dock="Right"
                                Content="Descargar plantilla"
                                Style="{StaticResource TertiaryButton}"
                                Padding="14,0"
                                Click="DownloadTemplate_Click"/>
                    </DockPanel>
                </Border>

                <!-- DataGrid with scroll hints -->
                <Grid>
                    <DataGrid x:Name="WorksetsGrid"
                              Style="{StaticResource BIMPillsDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Extended"
                              MouseDoubleClick="WorksetsGrid_DoubleClick">
                        <DataGrid.Columns>
                            <!-- Checkbox -->
                            <DataGridTemplateColumn Width="36" MinWidth="36" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Click="WorksetCheckBox_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="NOMBRE"     Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="ESTADO"     Binding="{Binding StatusLabel}" Width="80"/>
                            <DataGridTextColumn Header="ELEMENTOS"  Binding="{Binding ElementCount}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PROPIETARIO" Binding="{Binding Owner}"       Width="100"/>
                            <DataGridTextColumn Header="EDITABLE"    Binding="{Binding EditableLabel}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="ScrollUpHint"
                               Text="&#x25B2; más elementos arriba"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                    <TextBlock x:Name="ScrollDownHint"
                               Text="&#x25BC; más elementos abajo"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                </Grid>

            </DockPanel>
        </Border>
    </DockPanel>
</Window>
