<Window x:Class="BIMPills.UI.Gestion.GestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Gestión"
        Width="720" Height="580"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32" Margin="0,0,12,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel>
                    <TextBlock Text="Gestión"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TitleText"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SubtitleText"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBlock x:Name="FooterText"
                       DockPanel.Dock="Left"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI"/>
            <Button Content="Cerrar"
                    DockPanel.Dock="Right"
                    Style="{StaticResource SecondaryButton}"
                    Width="80"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"/>
        </DockPanel>

        <!-- Main content -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#E3F2FD" Margin="0,0,10,0">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Subproyectos"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Crear y gestionar subproyectos (Worksets)"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Worksharing notice -->
                <Border x:Name="WorksharingNotice"
                        DockPanel.Dock="Top"
                        Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,0,0,1"
                        Padding="14,7">
                    <TextBlock FontSize="11" Foreground="#2E7D32" FontFamily="Segoe UI">
                        <Run Text="&#x2714;"/> Worksharing habilitado — Los cambios se sincronizarán al guardar
                    </TextBlock>
                </Border>

                <!-- No worksharing warning -->
                <Border x:Name="NoWorksharingNotice"
                        DockPanel.Dock="Top"
                        Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="0,0,0,1"
                        Padding="14,7"
                        Visibility="Collapsed">
                    <TextBlock FontSize="11" Foreground="#E65100" FontFamily="Segoe UI">
                        <Run Text="&#x26A0;"/> Este modelo no tiene Worksharing habilitado. Los subproyectos no están disponibles.
                    </TextBlock>
                </Border>

                <!-- Toolbar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#F2F2F7" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnNewWorkset"
                                Content="  + Nuevo subproyecto"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="11" Padding="10,5"
                                Click="NewWorkset_Click"/>
                        <Border Width="1" Height="20" Background="#E5E5EA" Margin="10,0"/>
                        <Button Content="  Importar Excel"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="11" Padding="10,5"
                                Click="ImportExcel_Click"/>
                        <Button Content="  Exportar Excel"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="11" Padding="10,5"
                                Margin="6,0,0,0"
                                Click="ExportExcel_Click"/>
                        <Button Content="  Descargar plantilla"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="11" Padding="10,5"
                                Margin="6,0,0,0"
                                Click="DownloadTemplate_Click"/>
                        <TextBlock x:Name="WorksetCountText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- DataGrid with scroll hints -->
                <Grid>
                    <DataGrid x:Name="WorksetsGrid"
                              Style="{StaticResource BIMPillsDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              MouseDoubleClick="WorksetsGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding StatusLabel}" Width="80" />
                            <DataGridTextColumn Header="ELEMENTOS" Binding="{Binding ElementCount}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PROPIETARIO" Binding="{Binding Owner}" Width="100" />
                            <DataGridTextColumn Header="EDITABLE" Binding="{Binding EditableLabel}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="ScrollUpHint"
                               Text="&#x25B2; más elementos arriba"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                    <TextBlock x:Name="ScrollDownHint"
                               Text="&#x25BC; más elementos abajo"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                </Grid>

            </DockPanel>
        </Border>
    </DockPanel>
</Window>
