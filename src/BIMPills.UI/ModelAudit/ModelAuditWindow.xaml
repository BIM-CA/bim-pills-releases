<Window x:Class="BIMPills.UI.ModelAudit.ModelAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIMPills.UI.ModelAudit"
        xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
        Title="BIM Pills — Auditoría de Modelo"
        Width="920" Height="720"
        MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para botón primario azul oscuro (exportar PDF) -->
            <Style x:Key="DarkPrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#212B37"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="20,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3A4A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1A2230"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#A0A0A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Badge de tipo para purgables -->
            <Style x:Key="TypeBadge" TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Chip de filtro para purgables (ToggleButton) -->
            <Style x:Key="FilterChip" TargetType="ToggleButton">
                <Setter Property="Padding" Value="10,3"/>
                <Setter Property="Margin" Value="0,0,5,0"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Foreground" Value="#212B37"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ChipBorder"
                                    Background="White"
                                    BorderBrush="#DADADF"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#1565C0"/>
                                    <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#1565C0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#E8F0FE"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="ChipBorder" Property="Background" Value="#1256A4"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Auditoría"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="DocumentName"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SubtitleText"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="7"
                                Background="#E3F2FD" Margin="0,0,10,0">
                            <bimca:Icon Slug="barchart" Size="16"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Auditoría de Modelo"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Análisis de calidad del modelo BIM"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Footer inside content card -->
                <!-- Footer — Cerrar left, actions right -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="CloseButton_Click"/>

                        <Button DockPanel.Dock="Right"
                                Content="Exportar informe"
                                Style="{StaticResource SecondaryButton}"
                                Padding="18,0"
                                Click="OpenExportAudit_Click"/>
                    </DockPanel>
                </Border>

                <!-- Content area: dashboard (Auto) + tabs (fill remaining) -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                        <!-- Dashboard de Salud del Modelo -->
                        <Border Grid.Row="0" Margin="14,14,14,0"
                                Background="#F9F9FB" CornerRadius="8"
                                BorderBrush="#E5E5EA" BorderThickness="0.5"
                                Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Indicador circular de salud -->
                                <Grid Grid.Column="0" Width="96" Height="88" Margin="0,0,20,0">
                                    <Grid HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Width="80" Height="80">
                                        <!-- Fondo del anillo -->
                                        <Ellipse Width="80" Height="80" StrokeThickness="6" Stroke="#E5E5EA"/>
                                        <!-- Anillo de progreso completo (visible solo al 100%) -->
                                        <Ellipse x:Name="HealthFullRing" Width="80" Height="80"
                                                 StrokeThickness="6" Visibility="Collapsed">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush x:Name="HealthFullRingBrush" Color="#34C759"/>
                                            </Ellipse.Stroke>
                                        </Ellipse>
                                        <!-- Anillo de progreso parcial -->
                                        <Canvas Width="80" Height="80">
                                            <Path x:Name="HealthArc" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                <Path.Stroke>
                                                    <SolidColorBrush x:Name="HealthArcBrush" Color="#34C759"/>
                                                </Path.Stroke>
                                            </Path>
                                        </Canvas>
                                        <!-- Score central -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock x:Name="HealthScoreText"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontFamily="Segoe UI"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="HealthLevelText"
                                                       FontSize="9" FontWeight="Medium"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Botón de información (i) -->
                                    <Button x:Name="HealthInfoButton"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Width="22" Height="22"
                                            Cursor="Hand"
                                            Click="HealthInfo_Click"
                                            ToolTip="Ver metodología de evaluación">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="InfoBorder"
                                                        Width="22" Height="22"
                                                        CornerRadius="11"
                                                        Background="#E5E5EA"
                                                        BorderThickness="0">
                                                    <TextBlock Text="i"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               FontFamily="Georgia"
                                                               FontStyle="Italic"
                                                               Foreground="#86868B"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="InfoBorder" Property="Background" Value="#007AFF"/>
                                                        <Setter TargetName="InfoBorder" Property="TextBlock.Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Métricas en tarjetas -->
                                <UniformGrid Grid.Column="1" Rows="1" Columns="4">
                                    <!-- Peso del modelo -->
                                    <Border Margin="4,0" Padding="12,10" Background="White" CornerRadius="8"
                                            BorderBrush="#E5E5EA" BorderThickness="0.5">
                                        <StackPanel>
                                            <TextBlock Text="Peso" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="FileSizeText"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontFamily="Segoe UI"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Elementos -->
                                    <Border Margin="4,0" Padding="12,10" Background="White" CornerRadius="8"
                                            BorderBrush="#E5E5EA" BorderThickness="0.5">
                                        <StackPanel>
                                            <TextBlock Text="Elementos" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="TotalElementsText"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontFamily="Segoe UI"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Advertencias -->
                                    <Border Margin="4,0" Padding="12,10" Background="White" CornerRadius="8"
                                            BorderBrush="#E5E5EA" BorderThickness="0.5">
                                        <StackPanel>
                                            <TextBlock Text="Advertencias" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="WarningsCountText"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Purgables -->
                                    <Border Margin="4,0" Padding="12,10" Background="White" CornerRadius="8"
                                            BorderBrush="#E5E5EA" BorderThickness="0.5">
                                        <StackPanel>
                                            <TextBlock Text="Purgables" FontSize="11" Foreground="#8E8E93" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="PurgeableCountText"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontFamily="Segoe UI"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- Pestañas con datos detallados -->
                        <Border Grid.Row="1" Margin="14,12,14,14">
                            <TabControl Style="{StaticResource BIMPillsTabControl}"
                                        Margin="0">

                                <!-- Advertencias -->
                                <TabItem Header="{Binding WarningsHeader}" Style="{StaticResource BIMPillsTabItem}">
                                    <Grid Margin="0,8,0,0">
                                        <DataGrid x:Name="WarningsGrid"
                                                  Style="{StaticResource BIMPillsDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Severidad"    Binding="{Binding Severity}"     Width="100"/>
                                                <DataGridTextColumn Header="Descripción"  Binding="{Binding Description}"  Width="*"/>
                                                <DataGridTextColumn Header="Elementos"    Binding="{Binding ElementCount}" Width="90"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock x:Name="WarningsScrollUp" Text="&#x25B2; más advertencias arriba"
                                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                                   FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                   Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                                        <TextBlock x:Name="WarningsScrollDown" Text="&#x25BC; más advertencias abajo"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                   Background="#EEFFFFFF" Padding="12,3"
                                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                                    </Grid>
                                </TabItem>

                                <!-- Familias agrupadas por categoría -->
                                <TabItem Header="{Binding FamiliesHeader}" Style="{StaticResource BIMPillsTabItem}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Summary bar -->
                                        <TextBlock x:Name="FamiliesSummaryText"
                                                   Grid.Row="0"
                                                   FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="#86868B"
                                                   Margin="4,8,4,4"/>

                                        <!-- Grouped families -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="FamiliesGrouped">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Margin="0,0,0,2">
                                                            <Expander IsExpanded="True" Padding="0">
                                                                <Expander.Header>
                                                                    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Expander}, Converter={x:Static local:SubtractConverter.Instance}}">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" CornerRadius="4" Padding="8,2" Margin="0,0,8,0"
                                                                                Background="{Binding BadgeBackground}">
                                                                            <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="{Binding BadgeForeground}" FontFamily="Segoe UI"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="1" Text="{Binding CountLabel}"
                                                                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="3" Text="{Binding SizeLabel}"
                                                                                   FontSize="11" FontWeight="SemiBold" Foreground="#212B37"
                                                                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                                                                   Margin="0,0,8,0"/>
                                                                    </Grid>
                                                                </Expander.Header>
                                                                <DataGrid ItemsSource="{Binding Families}"
                                                                          Style="{StaticResource BIMPillsDataGrid}"
                                                                          Margin="20,0,0,4"
                                                                          MaxHeight="200">
                                                                    <DataGrid.Columns>
                                                                        <DataGridTextColumn Header="Familia"    Binding="{Binding Name}"          Width="*"/>
                                                                        <DataGridTextColumn Header="Tamaño"     Binding="{Binding SizeLabel}"     Width="90"/>
                                                                        <DataGridTextColumn Header="Instancias" Binding="{Binding InstanceCount}" Width="80"/>
                                                                    </DataGrid.Columns>
                                                                </DataGrid>
                                                            </Expander>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>

                                <!-- Vistas sin colocar -->
                                <TabItem Header="{Binding ViewsHeader}" Style="{StaticResource BIMPillsTabItem}">
                                    <Grid Margin="0,8,0,0">
                                        <DataGrid x:Name="ViewsGrid"
                                                  Style="{StaticResource BIMPillsDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Vista"  Binding="{Binding Name}"     Width="*"/>
                                                <DataGridTextColumn Header="Tipo"   Binding="{Binding ViewType}" Width="160"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock x:Name="ViewsScrollUp" Text="&#x25B2; más vistas arriba"
                                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                                   FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                   Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                                        <TextBlock x:Name="ViewsScrollDown" Text="&#x25BC; más vistas abajo"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                   Background="#EEFFFFFF" Padding="12,3"
                                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                                    </Grid>
                                </TabItem>

                                <!-- Elementos sin categoría -->
                                <TabItem Header="{Binding OrphansHeader}" Style="{StaticResource BIMPillsTabItem}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Info callout -->
                                        <Border Grid.Row="0"
                                                Background="#FFF8E7" CornerRadius="6"
                                                BorderBrush="#FDE68A" BorderThickness="1"
                                                Margin="0,8,0,4" Padding="12,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x26A0;"
                                                           FontSize="13" Foreground="#B45309"
                                                           Margin="0,0,8,0" VerticalAlignment="Top"/>
                                                <TextBlock FontSize="11" FontFamily="Segoe UI"
                                                           Foreground="#78350F" TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold">Elementos sin categoría: </Run>
                                                    <Run>importaciones CAD, enlaces Revit y grupos que Revit no clasificó. Los recursos internos del sistema (fases, patrones, parámetros) se excluyen automáticamente. Pasa el cursor sobre cada fila para ver su descripción detallada antes de eliminar.</Run>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Barra de acción / filtro -->
                                        <Border Grid.Row="1" Background="#F9F9FB" CornerRadius="6"
                                                Padding="10,7" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock x:Name="OrphanSelectionText"
                                                           Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" FontFamily="Segoe UI"
                                                           Foreground="#86868B"
                                                           Text="0 elementos"/>

                                                <!-- Filtro Solo borrables -->
                                                <ToggleButton x:Name="OrphanFilterDeletableBtn"
                                                              Grid.Column="1"
                                                              Content="Solo borrables"
                                                              FontSize="11" FontFamily="Segoe UI"
                                                              Padding="10,4"
                                                              Margin="0,0,8,0"
                                                              Cursor="Hand"
                                                              Checked="OrphanFilterDeletable_Changed"
                                                              Unchecked="OrphanFilterDeletable_Changed">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="Foreground" Value="#555"/>
                                                            <Setter Property="BorderBrush" Value="#D1D1D6"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="5"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="Background" Value="#FFF0EB"/>
                                                                    <Setter Property="Foreground" Value="#EF6337"/>
                                                                    <Setter Property="BorderBrush" Value="#EF6337"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F5F5F7"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>

                                                <Button x:Name="OrphanSelectAllButton"
                                                        Grid.Column="2"
                                                        Content="Seleccionar todo"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="12,5" FontSize="12"
                                                        Visibility="Collapsed"
                                                        Click="OrphanSelectAll_Click"/>

                                                <Button x:Name="DeleteOrphansButton"
                                                        Grid.Column="2"
                                                        Content="Eliminar seleccionados"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Padding="12,5" FontSize="12"
                                                        IsEnabled="False"
                                                        Visibility="Collapsed"
                                                        Click="DeleteOrphans_Click"/>
                                            </Grid>
                                        </Border>

                                        <!-- DataGrid + scroll hints -->
                                        <Grid Grid.Row="2">
                                            <DataGrid x:Name="OrphansGrid"
                                                      Style="{StaticResource BIMPillsDataGrid}"
                                                      IsReadOnly="False"
                                                      SelectionMode="Single">
                                                <DataGrid.RowStyle>
                                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                                        <Setter Property="ToolTip" Value="{Binding Description}"/>
                                                    </Style>
                                                </DataGrid.RowStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="" Width="40">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                          IsEnabled="{Binding CanDelete}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Click="OrphanCheckBox_Click"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Nombre"      Binding="{Binding Name}"        Width="220" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Tipo"        Binding="{Binding ClassName}"   Width="150" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*"   IsReadOnly="True">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTemplateColumn Header="Purgable" Width="80" IsReadOnly="True">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="4" Padding="8,2"
                                                                        HorizontalAlignment="Left"
                                                                        Background="{Binding CanDeleteBrush}">
                                                                    <TextBlock Text="{Binding CanDeleteLabel}"
                                                                               FontSize="11" FontFamily="Segoe UI"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="ID"       Binding="{Binding Id}"        Width="75"  IsReadOnly="True"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <TextBlock x:Name="OrphansScrollUp" Text="&#x25B2; más elementos arriba"
                                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                       Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                                                       IsHitTestVisible="False" Visibility="Collapsed"/>
                                            <TextBlock x:Name="OrphansScrollDown" Text="&#x25BC; más elementos abajo"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                       Background="#EEFFFFFF" Padding="12,3"
                                                       IsHitTestVisible="False" Visibility="Collapsed"/>
                                        </Grid>
                                    </Grid>
                                </TabItem>

                                <!-- Elementos purgables -->
                                <TabItem Header="{Binding PurgeableHeader}" Style="{StaticResource BIMPillsTabItem}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Barra de acción: búsqueda, filtros y botones -->
                                        <Border Grid.Row="0" Background="#F9F9FB" CornerRadius="6"
                                                Padding="10,8" Margin="0,8,0,4">

                                            <!-- Fila única: búsqueda + filtro dropdown + selección + acciones -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Buscador -->
                                                <Border Grid.Column="0"
                                                        Background="White" CornerRadius="4"
                                                        BorderBrush="#E0E0E0" BorderThickness="1"
                                                        Padding="6,4">
                                                    <Grid>
                                                        <TextBox x:Name="PurgeSearchBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 FontSize="12" FontFamily="Segoe UI"
                                                                 Foreground="#212B37"
                                                                 VerticalAlignment="Center"
                                                                 TextChanged="PurgeSearch_TextChanged"/>
                                                        <TextBlock Text="🔍  Buscar por nombre..."
                                                                   FontSize="11" FontFamily="Segoe UI"
                                                                   Foreground="#AEAEB2"
                                                                   IsHitTestVisible="False"
                                                                   VerticalAlignment="Center"
                                                                   Margin="2,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Text, ElementName=PurgeSearchBox}" Value="">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>

                                                <!-- Filtro por tipo (dropdown dinámico) -->
                                                <ComboBox x:Name="PurgeTypeFilter"
                                                          Grid.Column="2"
                                                          FontSize="12" FontFamily="Segoe UI"
                                                          Foreground="#212B37"
                                                          Background="White"
                                                          BorderBrush="#E0E0E0" BorderThickness="1"
                                                          Padding="6,4"
                                                          VerticalContentAlignment="Center"
                                                          SelectionChanged="PurgeTypeFilter_SelectionChanged"/>

                                                <TextBlock x:Name="PurgeSelectionText"
                                                           Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0"
                                                           FontSize="12" FontFamily="Segoe UI"
                                                           Foreground="#86868B"
                                                           Text="0 de 0 seleccionados"/>

                                                <Button x:Name="SelectAllButton"
                                                        Grid.Column="4"
                                                        Content="Seleccionar todo"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="12,5" FontSize="12"
                                                        Margin="8,0,8,0"
                                                        Click="SelectAll_Click"/>

                                                <Button x:Name="PurgeSelectedButton"
                                                        Grid.Column="5"
                                                        Content="Purgar seleccionados"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Padding="12,5" FontSize="12"
                                                        IsEnabled="False"
                                                        Click="PurgeSelected_Click"/>
                                            </Grid>

                                        </Border>

                                        <!-- Grid con DataGrid + scroll hints -->
                                        <Grid Grid.Row="1">
                                            <DataGrid x:Name="PurgeableGrid"
                                                      Style="{StaticResource BIMPillsDataGrid}"
                                                      IsReadOnly="False"
                                                      SelectionMode="Extended">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="" Width="40">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Click="PurgeCheckBox_Click"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Nombre"    Binding="{Binding Name}"     Width="*"   IsReadOnly="True"/>
                                                    <DataGridTemplateColumn Header="Tipo"  Width="110" IsReadOnly="True">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource TypeBadge}"
                                                                        Background="{Binding ItemType, Converter={x:Static local:TypeToBrushConverter.Instance}}">
                                                                    <TextBlock Text="{Binding ItemType}"
                                                                               FontSize="11" FontFamily="Segoe UI"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="130" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Tamaño"    Binding="{Binding SizeLabel}" Width="80" IsReadOnly="True"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="ScrollUpHint"
                                                       Text="&#x25B2; más elementos arriba"
                                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                       Background="#DDFFFFFF" Padding="8,2"
                                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                                            <TextBlock x:Name="ScrollDownHint"
                                                       Text="&#x25BC; más elementos abajo"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                       FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                                                       Background="#DDFFFFFF" Padding="8,2"
                                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                                        </Grid>
                                    </Grid>
                                </TabItem>

                            </TabControl>
                        </Border>

                </Grid>

            </DockPanel>
        </Border>
    </DockPanel>
</Window>
