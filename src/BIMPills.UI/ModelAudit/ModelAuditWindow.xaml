<Window x:Class="BIMPills.UI.ModelAudit.ModelAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Auditoría de Modelo"
        Width="820" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock x:Name="SubtitleText" FontSize="11" Foreground="#666"/>
        </StackPanel>

        <!-- Footer -->
        <Button DockPanel.Dock="Bottom"
                Content="Cerrar"
                Width="90" HorizontalAlignment="Right"
                Margin="0,12,0,0" Padding="8,4"
                Click="CloseButton_Click"/>

        <!-- Tabs -->
        <TabControl Background="Transparent" BorderThickness="0">

            <!-- Advertencias -->
            <TabItem Header="{Binding WarningsHeader}">
                <DataGrid x:Name="WarningsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Severidad"    Binding="{Binding Severity}"     Width="90"/>
                        <DataGridTextColumn Header="Descripción"  Binding="{Binding Description}"  Width="*"/>
                        <DataGridTextColumn Header="Elementos"    Binding="{Binding ElementCount}"  Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Familias -->
            <TabItem Header="{Binding FamiliesHeader}">
                <DataGrid x:Name="FamiliesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Familia"    Binding="{Binding Name}"          Width="*"/>
                        <DataGridTextColumn Header="Categoría"  Binding="{Binding Category}"      Width="160"/>
                        <DataGridTextColumn Header="Instancias" Binding="{Binding InstanceCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Vistas sin colocar -->
            <TabItem Header="{Binding ViewsHeader}">
                <DataGrid x:Name="ViewsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vista"  Binding="{Binding Name}"     Width="*"/>
                        <DataGridTextColumn Header="Tipo"   Binding="{Binding ViewType}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Elementos huérfanos -->
            <TabItem Header="{Binding OrphansHeader}">
                <DataGrid x:Name="OrphansGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"     Binding="{Binding Id}"   Width="80"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
