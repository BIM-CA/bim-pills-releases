<Window x:Class="BIMPills.UI.ModelAudit.ModelAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Auditoría de Modelo"
        Width="860" Height="620"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Contenedor principal con márgenes amplios macOS-style -->
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             Encabezado — Barra superior estilo macOS
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,0.5"
                Padding="24,18,24,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo BIMPills (PNG real) -->
                <Image Grid.Column="0"
                       Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="28" Height="44"
                       Margin="0,0,14,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Títulos en 3 filas con espaciado uniforme -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Fila 1: "Auditoría de Modelo" en naranja BIM-CA -->
                    <TextBlock x:Name="AuditLabel"
                               Text="Auditoría de Modelo"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="#EF6337"
                               FontFamily="Segoe UI"/>
                    <!-- Fila 2: Nombre del archivo en negro -->
                    <TextBlock x:Name="DocumentName"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#212B37"
                               FontFamily="Segoe UI"
                               Margin="0,3,0,0"/>
                    <!-- Fila 3: Modelo local/colaborativo -->
                    <TextBlock x:Name="SubtitleText"
                               Style="{StaticResource CaptionText}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             Contenido principal — Pestañas con datos
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Margin="20,16,20,0">
            <Border Background="White"
                    CornerRadius="10"
                    BorderBrush="#E5E5EA"
                    BorderThickness="0.5"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Color="Black"/>
                </Border.Effect>

                <TabControl Style="{StaticResource BIMPillsTabControl}"
                            Margin="12,8,12,12">

                    <!-- Advertencias -->
                    <TabItem Header="{Binding WarningsHeader}" Style="{StaticResource BIMPillsTabItem}">
                        <DataGrid x:Name="WarningsGrid"
                                  Style="{StaticResource BIMPillsDataGrid}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severidad"    Binding="{Binding Severity}"     Width="100"/>
                                <DataGridTextColumn Header="Descripción"  Binding="{Binding Description}"  Width="*"/>
                                <DataGridTextColumn Header="Elementos"    Binding="{Binding ElementCount}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Familias -->
                    <TabItem Header="{Binding FamiliesHeader}" Style="{StaticResource BIMPillsTabItem}">
                        <DataGrid x:Name="FamiliesGrid"
                                  Style="{StaticResource BIMPillsDataGrid}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Familia"    Binding="{Binding Name}"          Width="*"/>
                                <DataGridTextColumn Header="Categoría"  Binding="{Binding Category}"      Width="160"/>
                                <DataGridTextColumn Header="Instancias" Binding="{Binding InstanceCount}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Vistas sin colocar -->
                    <TabItem Header="{Binding ViewsHeader}" Style="{StaticResource BIMPillsTabItem}">
                        <DataGrid x:Name="ViewsGrid"
                                  Style="{StaticResource BIMPillsDataGrid}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Vista"  Binding="{Binding Name}"     Width="*"/>
                                <DataGridTextColumn Header="Tipo"   Binding="{Binding ViewType}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Elementos huérfanos -->
                    <TabItem Header="{Binding OrphansHeader}" Style="{StaticResource BIMPillsTabItem}">
                        <DataGrid x:Name="OrphansGrid"
                                  Style="{StaticResource BIMPillsDataGrid}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"     Binding="{Binding Id}"   Width="100"/>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                </TabControl>
            </Border>
        </Border>

        <!-- ═══════════════════════════════════════════
             Pie de página — macOS-style toolbar bottom
             ═══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Padding="24,12,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info del resumen -->
                <TextBlock Grid.Column="0"
                           x:Name="SummaryText"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"/>

                <!-- Botón cerrar -->
                <Button Grid.Column="1"
                        Content="Cerrar"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
