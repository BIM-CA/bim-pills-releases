<Window x:Class="BIMPills.UI.ModelAudit.ModelAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Auditoría de Modelo"
        Width="820" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Encabezado -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}"/>
            <TextBlock x:Name="SubtitleText" Style="{StaticResource CaptionText}"/>
        </StackPanel>

        <!-- Pie de página -->
        <Button DockPanel.Dock="Bottom"
                Content="Cerrar"
                Style="{StaticResource SecondaryButton}"
                Width="90" HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="CloseButton_Click"/>

        <!-- Pestañas -->
        <TabControl Style="{StaticResource BIMPillsTabControl}">

            <!-- Advertencias -->
            <TabItem Header="{Binding WarningsHeader}" Style="{StaticResource BIMPillsTabItem}">
                <DataGrid x:Name="WarningsGrid"
                          Style="{StaticResource BIMPillsDataGrid}"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Severidad"    Binding="{Binding Severity}"     Width="90"/>
                        <DataGridTextColumn Header="Descripción"  Binding="{Binding Description}"  Width="*"/>
                        <DataGridTextColumn Header="Elementos"    Binding="{Binding ElementCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Familias -->
            <TabItem Header="{Binding FamiliesHeader}" Style="{StaticResource BIMPillsTabItem}">
                <DataGrid x:Name="FamiliesGrid"
                          Style="{StaticResource BIMPillsDataGrid}"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Familia"    Binding="{Binding Name}"          Width="*"/>
                        <DataGridTextColumn Header="Categoría"  Binding="{Binding Category}"      Width="160"/>
                        <DataGridTextColumn Header="Instancias" Binding="{Binding InstanceCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Vistas sin colocar -->
            <TabItem Header="{Binding ViewsHeader}" Style="{StaticResource BIMPillsTabItem}">
                <DataGrid x:Name="ViewsGrid"
                          Style="{StaticResource BIMPillsDataGrid}"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vista"  Binding="{Binding Name}"     Width="*"/>
                        <DataGridTextColumn Header="Tipo"   Binding="{Binding ViewType}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Elementos huérfanos -->
            <TabItem Header="{Binding OrphansHeader}" Style="{StaticResource BIMPillsTabItem}">
                <DataGrid x:Name="OrphansGrid"
                          Style="{StaticResource BIMPillsDataGrid}"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"     Binding="{Binding Id}"   Width="80"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
