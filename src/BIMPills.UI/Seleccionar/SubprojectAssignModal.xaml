<Window x:Class="BIMPills.UI.Seleccionar.SubprojectAssignModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Asignar Subproyecto"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel>

        <!-- Header -->
        <Border Background="#16A34A" Padding="16,12">
            <StackPanel>
                <TextBlock Text="SELECCIONAR · SUBPROYECTO"
                           FontSize="10" Foreground="#BFFFFFFF" FontFamily="Segoe UI"/>
                <TextBlock Text="Asignar workset a elementos"
                           FontSize="13" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="16,14,16,14">

            <!-- Source mode -->
            <TextBlock Text="ASIGNAR A" FontSize="10" FontWeight="SemiBold"
                       Foreground="#86868B" FontFamily="Segoe UI" Margin="0,0,0,8"/>

            <RadioButton x:Name="UseSelectionRadio"
                         Content="Selección activa en Revit"
                         IsChecked="True" FontSize="12" FontFamily="Segoe UI"
                         Margin="0,0,0,5"
                         Checked="SourceMode_Changed"/>
            <RadioButton x:Name="UseFilterRadio"
                         Content="Resultado de filtro guardado"
                         FontSize="12" FontFamily="Segoe UI"
                         Margin="0,0,0,12"
                         Checked="SourceMode_Changed"/>

            <!-- Filter preset selector (visible only when UseFilter) -->
            <Border x:Name="FilterPresetRow" Visibility="Collapsed" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="FilterPresetCombo" Height="30"
                              FontSize="11" FontFamily="Segoe UI"
                              DisplayMemberPath="Name"/>
                </Grid>
            </Border>

            <!-- Workset selector -->
            <Rectangle Height="1" Fill="#E5E5EA" Margin="0,0,0,12"/>

            <TextBlock Text="SUBPROYECTO DESTINO" FontSize="10" FontWeight="SemiBold"
                       Foreground="#86868B" FontFamily="Segoe UI" Margin="0,0,0,8"/>

            <ComboBox x:Name="WorksetCombo" Height="32"
                      FontSize="12" FontFamily="Segoe UI"
                      Margin="0,0,0,12"/>

            <!-- Non-workshared warning -->
            <Border x:Name="NoWorksetsWarning" Background="#FFF8E1" CornerRadius="6"
                    Padding="10,8" Margin="0,0,0,12" Visibility="Collapsed">
                <TextBlock Text="⚠ El modelo no tiene worksharing habilitado."
                           FontSize="11" Foreground="#E65100" FontFamily="Segoe UI"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="34" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2" x:Name="AssignButton"
                        Height="34" Content="Asignar Subproyecto"
                        Style="{StaticResource PrimaryButton}"
                        Click="Assign_Click"/>
            </Grid>

        </StackPanel>
    </StackPanel>
</Window>
