<Window x:Class="BIMPills.UI.Seleccionar.FilterSelectionModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Selección por Filtros"
        Width="480" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Body -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="SELECCIONAR · FILTROS"
                           FontSize="10" Foreground="#BFFFFFFF" FontFamily="Segoe UI"/>
                <TextBlock Text="Definir condiciones de selección"
                           FontSize="13" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,14,16,10">

                <!-- Categoría -->
                <TextBlock Text="CATEGORÍA" FontSize="10" FontWeight="SemiBold"
                           Foreground="#86868B" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryCombo" Height="32"
                          FontSize="12" FontFamily="Segoe UI"
                          SelectionChanged="CategoryCombo_SelectionChanged"
                          Margin="0,0,0,14"/>

                <!-- Lógica -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CONDICIONES" FontSize="10" FontWeight="SemiBold"
                               Foreground="#86868B" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Lógica:" FontSize="11"
                               Foreground="#86868B" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Lógica:" FontSize="11" Foreground="#86868B"
                                   FontFamily="Segoe UI" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <RadioButton x:Name="AndRadio" Content="Y (AND)" IsChecked="True"
                                     FontSize="11" FontFamily="Segoe UI" Margin="0,0,10,0"/>
                        <RadioButton x:Name="OrRadio"  Content="O (OR)"
                                     FontSize="11" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>

                <!-- Conditions list -->
                <StackPanel x:Name="ConditionsPanel" Margin="0,0,0,8"/>

                <!-- Add condition button -->
                <Button x:Name="AddConditionButton"
                        Height="30" Click="AddCondition_Click"
                        HorizontalAlignment="Left" Padding="10,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                            <Setter Property="Background" Value="#F5F5F7"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Agregar condición" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Presets section -->
                <Rectangle Height="1" Fill="#E5E5EA" Margin="0,16,0,12"/>
                <TextBlock Text="PRESETS GUARDADOS" FontSize="10" FontWeight="SemiBold"
                           Foreground="#86868B" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="PresetsCombo" Grid.Column="0" Height="30"
                              FontSize="11" FontFamily="Segoe UI"
                              DisplayMemberPath="Name"
                              SelectionChanged="PresetsCombo_SelectionChanged"/>
                    <Button Grid.Column="2" Height="30" Padding="10,0"
                            Content="Cargar" FontSize="11"
                            Style="{StaticResource SecondaryButton}"
                            Click="LoadPreset_Click"/>
                    <Button Grid.Column="4" Height="30" Padding="10,0"
                            Content="Guardar como..." FontSize="11"
                            Style="{StaticResource SecondaryButton}"
                            Click="SavePreset_Click"/>
                </Grid>

                <!-- Preview count badge -->
                <Border x:Name="PreviewBadge" Background="#EFF6FF" CornerRadius="6"
                        Padding="10,6" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="PreviewLabel"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#E5E5EA" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="PreviewButton"
                        Height="34" Content="Vista previa (conteo)"
                        Style="{StaticResource SecondaryButton}"
                        Click="Preview_Click"/>

                <Button Grid.Column="2" Height="34" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"/>

                <Button Grid.Column="4" x:Name="SelectButton"
                        Height="34" Content="Seleccionar en Revit"
                        Style="{StaticResource PrimaryButton}"
                        Click="Select_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
