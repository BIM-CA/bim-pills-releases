<Window x:Class="BIMPills.UI.Support.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="BIM Pills — Soporte"
        Width="400"
        Height="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="#010203"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid>

        <!-- WebView2: ocupa todo, fondo transparente vía DefaultBackgroundColor en code-behind -->
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>

        <!-- Panel de carga: spinner sobre fondo transparente (mismo color clave #010203) -->
        <Border x:Name="LoadingPanel" Background="#010203">
            <Ellipse x:Name="SpinnerRing"
                     Width="52" Height="52"
                     Stroke="#EF6337" StrokeThickness="3"
                     StrokeDashArray="8 18"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,22,22"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation
                                    Storyboard.TargetName="SpinnerRotate"
                                    Storyboard.TargetProperty="Angle"
                                    From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Border>

        <!-- Fallback: WebView2 Runtime no instalado -->
        <Border x:Name="FallbackPanel"
                Visibility="Collapsed"
                Background="#f3f4f6"
                CornerRadius="12"
                Margin="8">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="32">
                <TextBlock Text="⚠️" FontSize="36"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Se requiere WebView2 Runtime"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1a1a2e"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Para abrir el chat de soporte, instala WebView2 Runtime (gratuito, de Microsoft)."
                           FontSize="12" Foreground="#666"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" FontFamily="Segoe UI"
                           Margin="0,8,0,20"/>
                <Button Content="Descargar WebView2 Runtime"
                        Background="#EF6337" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" HorizontalAlignment="Center"
                        Click="DownloadWebView2_Click"
                        Margin="0,0,0,8"/>
                <Button Content="Ir al sitio web de soporte"
                        Background="Transparent" Foreground="#EF6337"
                        BorderBrush="#EF6337" BorderThickness="1" Padding="16,8"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" HorizontalAlignment="Center"
                        Click="OpenSupportWeb_Click"/>
            </StackPanel>
        </Border>

        <!-- Fallback: Intercom no pudo conectar (CDN, proxy, etc.) -->
        <Border x:Name="ConnectionFallbackPanel"
                Visibility="Collapsed"
                Background="#f3f4f6"
                CornerRadius="12"
                Margin="8">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="32">
                <TextBlock Text="🔌" FontSize="36"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Sin conexión al chat"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1a1a2e"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="No se pudo conectar al servicio de soporte. Visita nuestra web para contactarnos."
                           FontSize="12" Foreground="#666"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" FontFamily="Segoe UI"
                           Margin="0,8,0,20"/>
                <Button Content="Ir al sitio web de soporte"
                        Background="#EF6337" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" HorizontalAlignment="Center"
                        Click="OpenSupportWeb_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
