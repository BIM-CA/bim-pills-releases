<Window x:Class="BIMPills.UI.Licensing.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Activar Licencia"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header azul -->
            <RowDefinition Height="Auto"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="28,20,28,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="32" Height="50"
                       Margin="0,0,14,0"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BIMPills"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Activación de Licencia"
                               FontSize="12"
                               Foreground="#B3D4FF"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Contenido ───────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="28,20,28,24">

            <!-- Subtítulo -->
            <TextBlock Text="Ingresa tu License Key para activar BIMPills en esta máquina."
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"
                       FontFamily="Segoe UI"/>

            <!-- License Key -->
            <TextBlock Text="LICENSE KEY"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"

                       Margin="0,0,0,6"
                       FontFamily="Segoe UI"/>
            <Border Background="White"
                    BorderBrush="#DDE1EA"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,14">
                <TextBox x:Name="TxtLicenseKey"
                         FontSize="13"
                         FontFamily="Consolas"
                         Padding="10,8"
                         BorderThickness="0"
                         Background="Transparent"
                         MaxLength="64"
                         ToolTip="UUID de tu licencia (formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)"/>
            </Border>

            <!-- Status -->
            <Border x:Name="StatusBorder"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <TextBlock x:Name="StatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"/>
            </Border>

            <!-- Botones -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="BtnActivate"
                        Content="Activar licencia"
                        Style="{StaticResource PrimaryButton}"
                        Click="Activate_Click"
                        Height="36"/>

                <Button Grid.Column="2"
                        Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Height="36"
                        MinWidth="90"
                        Click="Cancel_Click"/>
            </Grid>

            <!-- Comprar link -->
            <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0">
                <Run Text="¿No tienes licencia? "
                     FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontFamily="Segoe UI"/>
                <Hyperlink Click="Buy_Click" TextDecorations="Underline">
                    <Run Text="Obtén una en bim-ca.com"
                         FontSize="11"
                         FontFamily="Segoe UI"/>
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>
