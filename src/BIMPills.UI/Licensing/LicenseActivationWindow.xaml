<Window x:Class="BIMPills.UI.Licensing.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Activar Licencia"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="28,24,28,24">

        <!-- Logo + título -->
        <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
               Width="36" Height="56"
               Margin="0,0,0,8"
               HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Text="Activar Licencia"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="Segoe UI"/>

        <TextBlock Text="Ingresa tu License Key para activar BIMPills en este equipo."
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,6,0,20"
                   FontFamily="Segoe UI"/>

        <!-- Formulario -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>

                <!-- Label -->
                <TextBlock Text="LICENSE KEY"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,6"
                           FontFamily="Segoe UI"/>

                <!-- Input -->
                <TextBox x:Name="TxtLicenseKey"
                         Style="{StaticResource InputTextBox}"
                         FontFamily="Consolas"
                         FontSize="13"
                         MaxLength="64"
                         ToolTip="UUID de tu licencia (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)"/>

            </StackPanel>
        </Border>

        <!-- Status -->
        <Border x:Name="StatusBorder"
                CornerRadius="7"
                Padding="12,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Botones -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Name="BtnActivate"
                    Content="Activar licencia"
                    Style="{StaticResource PrimaryButton}"
                    Click="Activate_Click"/>

            <Button Grid.Column="2"
                    Content="Cancelar"
                    Style="{StaticResource TertiaryButton}"
                    IsCancel="True"
                    MinWidth="90"
                    Click="Cancel_Click"/>
        </Grid>

        <!-- Comprar link -->
        <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0">
            <Run Text="¿No tienes licencia? "
                 FontSize="11"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontFamily="Segoe UI"/>
            <Hyperlink Click="Buy_Click" TextDecorations="None"
                       Foreground="{StaticResource AccentBrush}">
                <Run Text="Obtén una en bim-ca.com"
                     FontSize="11"
                     FontFamily="Segoe UI"/>
            </Hyperlink>
        </TextBlock>

    </StackPanel>
</Window>
