<Window x:Class="BIMPills.UI.Licensing.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Activar Licencia"
        Width="440" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="28,20,28,16">

        <!-- Header -->
        <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
               Width="36" Height="56"
               Margin="0,0,0,8"
               HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Text="Activar Licencia"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="Segoe UI"/>

        <TextBlock Text="Ingresa tu License Key para activar BIMPills en esta máquina."
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,16"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontFamily="Segoe UI"/>

        <!-- License Key input -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="License Key"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtLicenseKey"
                         FontSize="14"
                         FontFamily="Consolas"
                         Padding="8,6"
                         MaxLength="64"/>
            </StackPanel>
        </Border>

        <!-- Airtable API Key input -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Airtable API Key"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtApiKey"
                             FontSize="13"
                             FontFamily="Consolas"
                             Padding="8,6"
                             MaxLength="128"/>
            </StackPanel>
        </Border>

        <!-- Status message -->
        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontFamily="Segoe UI"/>

        <!-- Buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Activar"
                    Style="{StaticResource PrimaryButton}"
                    Click="Activate_Click"
                    x:Name="BtnActivate"/>

            <Button Grid.Column="2"
                    Content="Cancelar"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </Grid>

        <!-- Buy link -->
        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
            <Hyperlink x:Name="BuyLink" Click="Buy_Click">
                <Run Text="¿No tienes licencia? Compra aquí"
                     FontSize="11" FontFamily="Segoe UI"/>
            </Hyperlink>
        </TextBlock>

    </StackPanel>
</Window>
