<Window x:Class="BIMPills.UI.Updates.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Actualización disponible"
        Width="480" SizeToContent="Height"
        MinWidth="400" MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- Contenido principal -->
        <Grid x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Badge versión -->
            <RowDefinition Height="*"/>      <!-- Release notes -->
            <RowDefinition Height="Auto"/>   <!-- Footer botones -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource WhiteBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                Padding="20,14,20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Logo BIM Pills -->
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Actualización disponible"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock x:Name="SubtitleText"
                               Text="Una nueva versión de BIM Pills está lista"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Badge versión ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource WhiteBrush}"
                Padding="24,14,24,14"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <!-- Versión actual -->
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Versión actual"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <Border Background="#F0F0F5" CornerRadius="6"
                            Padding="10,4" Margin="0,4,0,0">
                        <TextBlock x:Name="CurrentVersionText"
                                   Text="beta 1.0"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Flecha -->
                <TextBlock Text="→"
                           FontSize="20"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,4"/>

                <!-- Nueva versión -->
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Nueva versión"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <Border Background="#EBF7EF" CornerRadius="6"
                            Padding="10,4" Margin="0,4,0,0">
                        <TextBlock x:Name="NewVersionText"
                                   Text="beta 1.1"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ── Release notes ────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundBrush}"
                Padding="20,16,20,16">
            <StackPanel>
                <TextBlock Text="Novedades"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,0,8"/>

                <Border Background="{StaticResource WhiteBrush}"
                        CornerRadius="8"
                        BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1"
                        MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12,14,12">
                        <TextBlock x:Name="ReleaseNotesText"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   LineHeight="20"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </ScrollViewer>
                </Border>

                <!-- Aviso de reinicio -->
                <Border Background="#FFF8EC"
                        CornerRadius="6"
                        BorderBrush="#FFE0A3" BorderThickness="1"
                        Padding="12,8,12,8"
                        Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0;" FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Top"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#7A4F00">
                            <Run Text="La actualización se instalará automáticamente al cerrar Revit."/>
                            <LineBreak/>
                            <Run Text="Guarda tu trabajo antes de cerrar." FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Footer ───────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource WhiteBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"
                Padding="20,14,20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Estado de descarga -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="Collapsed"/>
                    <ProgressBar x:Name="DownloadProgress"
                                 Height="3" Minimum="0" Maximum="100"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource SeparatorBrush}"
                                 Visibility="Collapsed"
                                 Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Botón Recordar después -->
                <Button Grid.Column="1"
                        x:Name="RemindLaterBtn"
                        Content="Recordar después"
                        Style="{StaticResource SecondaryButton}"
                        Width="140"
                        Click="RemindLater_Click"/>

                <!-- Botón Descargar y actualizar -->
                <Button Grid.Column="3"
                        x:Name="UpdateBtn"
                        Content="Descargar y actualizar"
                        Style="{StaticResource PrimaryButton}"
                        Width="160"
                        Click="Update_Click"/>
            </Grid>
        </Border>

        </Grid><!-- /MainContent -->

        <!-- ── Overlay de descarga ──────────────────────────────────────── -->
        <Grid x:Name="DownloadOverlay"
              Visibility="Collapsed"
              Background="#CC212B37">
            <Border Background="{StaticResource WhiteBrush}"
                    CornerRadius="12"
                    Padding="32,28,32,28"
                    Width="340"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18"
                                      BlurRadius="20" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">

                    <!-- Icono de estado -->
                    <TextBlock x:Name="OverlayIconText"
                               Text="&#x2B06;"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Título -->
                    <TextBlock x:Name="OverlayStatusText"
                               Text="Descargando actualización…"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,6"/>

                    <!-- Subtítulo (visible tras completarse) -->
                    <TextBlock x:Name="OverlaySubText"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,12"/>

                    <!-- Barra de progreso -->
                    <ProgressBar x:Name="OverlayProgress"
                                 Height="4" Width="240"
                                 Minimum="0" Maximum="100"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource SeparatorBrush}"
                                 Margin="0,8,0,0"/>

                    <!-- Aviso de no cerrar Revit (solo durante la descarga) -->
                    <Border x:Name="OverlayWarning"
                            Background="#FFF8EC"
                            CornerRadius="6"
                            BorderBrush="#FFE0A3" BorderThickness="1"
                            Padding="12,8"
                            Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;" FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="No cierres Revit durante la descarga."
                                       FontSize="11" Foreground="#7A4F00"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Botón cerrar (visible tras completar o error) -->
                    <Button x:Name="OverlayCloseBtn"
                            Content="Entendido, cerrar"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center"
                            Width="160"
                            Margin="0,16,0,0"
                            Visibility="Collapsed"
                            Click="OverlayClose_Click"/>

                </StackPanel>
            </Border>
        </Grid><!-- /DownloadOverlay -->

    </Grid>
</Window>
