<UserControl x:Class="BIMPills.UI.ProjectStandards.ProjectStandardsTransferPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Source document selector -->
        <Border DockPanel.Dock="Top"
                Background="#F8F9FA" Padding="14,10"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Documento fuente:"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="SourceDocCombo"
                          Style="{StaticResource BIMPillsComboBox}"
                          SelectionChanged="SourceDoc_Changed"/>
            </DockPanel>
        </Border>

        <!-- Status/summary bar at bottom -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Conflictos:" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ConflictCombo"
                              Style="{StaticResource BIMPillsComboBox}"
                              Width="175">
                        <ComboBoxItem Content="Reemplazar todo" Tag="Replace" IsSelected="True"/>
                        <ComboBoxItem Content="Omitir todo" Tag="Skip"/>
                        <ComboBoxItem Content="Elegir individualmente..." Tag="Individual"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Selecciona un documento fuente"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main 2-column layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: category list ─────────────────────────────────── -->
            <DockPanel Grid.Column="0" Margin="12,10,8,10">

                <TextBlock DockPanel.Dock="Top"
                           Text="CATEGORÍAS" FontSize="10" FontWeight="SemiBold"
                           Foreground="#86868B" FontFamily="Segoe UI"
                           Margin="2,0,0,6"/>

                <!-- Search categories + Todos -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="Todos"
                            Style="{StaticResource TertiaryButton}"
                            Padding="8,4" FontSize="11" Margin="6,0,0,0"
                            Click="SelectAllCategories_Click"/>
                    <TextBox x:Name="CategorySearchBox"
                             Style="{StaticResource BIMPillsTextBox}"
                             Height="28" FontSize="11"
                             Tag="Buscar categor&#237;a..."
                             TextChanged="CategorySearch_TextChanged"/>
                </DockPanel>

                <ListBox x:Name="CategoryListBox"
                         Style="{StaticResource BIMPillsListBox}"
                         SelectionChanged="Category_SelectionChanged">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#86868B" FontFamily="Segoe UI"
                                               Padding="8,6,8,4"
                                               Background="#F8F9FA"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                BorderBrush="#E5E5EA"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,7">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF3FF"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#C5CAE9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        Width="22" Height="22" CornerRadius="5"
                                        Background="#E3F2FD" Margin="0,0,7,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="#1565C0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Count badge -->
                                <Border Grid.Column="2"
                                        Background="#F2F2F7" CornerRadius="9"
                                        Padding="6,2" VerticalAlignment="Center"
                                        Visibility="{Binding HasCount, Converter={x:Null}}">
                                    <TextBlock x:Name="CountBadge"
                                               Text="{Binding ItemCount}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#86868B" FontFamily="Segoe UI"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="1"
                          Background="#E5E5EA"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ── Right: items panel ──────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Empty state: no source doc -->
                <Border x:Name="NoDocState"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="12"
                                Background="#F0F7FF" HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Selecciona un documento fuente"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Elige el proyecto del que quieres transferir normas."
                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="240"/>
                    </StackPanel>
                </Border>

                <!-- Empty state: only one project open -->
                <Border x:Name="SingleDocState" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="12"
                                Background="#FFF3E0" HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="#E65100"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Solo hay un proyecto abierto"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Abre otro proyecto en Revit para transferir normas entre documentos."
                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="260"/>
                    </StackPanel>
                </Border>

                <!-- Empty state: select a category -->
                <Border x:Name="NoCategoryState" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="12"
                                Background="#F0F7FF" HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Elige una categor&#237;a"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Selecciona una categor&#237;a a la izquierda para ver los elementos disponibles."
                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="240"/>
                    </StackPanel>
                </Border>

                <!-- Items panel -->
                <DockPanel x:Name="ItemsPanel" Visibility="Collapsed" Margin="10,10,12,10">

                    <!-- Toolbar: search + select all + category title -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right"
                                Content="Todos" Style="{StaticResource TertiaryButton}"
                                Padding="8,4" FontSize="11" Margin="6,0,0,0"
                                Click="SelectAll_Click"/>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource BIMPillsTextBox}"
                                 Height="28" FontSize="11"
                                 Tag="Buscar..."
                                 TextChanged="Search_TextChanged"/>
                    </DockPanel>

                    <!-- Summary bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#F8F9FA" CornerRadius="4"
                            Padding="10,5" Margin="0,0,0,6">
                        <DockPanel>
                            <TextBlock x:Name="CategoryTitle"
                                       DockPanel.Dock="Left"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectionSummary"
                                       DockPanel.Dock="Right"
                                       FontSize="10" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Items list -->
                    <ListBox x:Name="ItemsListBox"
                             Style="{StaticResource BIMPillsListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    BorderBrush="#E5E5EA"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,7">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F0F7FF"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#BBDEFB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              Click="ItemCheckBox_Click"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="10" Foreground="#86868B"
                                                   FontFamily="Segoe UI" Margin="0,1,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasDetail, Converter={x:Null}}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>

                <!-- Progress overlay — shown during transfer -->
                <Border x:Name="ProgressOverlay" Visibility="Collapsed"
                        Background="#F8F9FA" CornerRadius="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                        <!-- Spinner icon -->
                        <Border Width="56" Height="56" CornerRadius="14"
                                Background="#EFF3FF" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="24" Foreground="#1565C0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="ProgressTitle" Text="Transfiriendo..."
                                   FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ProgressDetail" Text=""
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" TextWrapping="Wrap"
                                   TextAlignment="Center" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <!-- Progress bar -->
                        <ProgressBar x:Name="ProgressBar"
                                     Height="6" Maximum="100" Value="0"
                                     Foreground="#1565C0" Background="#E5E5EA"
                                     BorderThickness="0"/>
                        <TextBlock x:Name="ProgressCount" Text=""
                                   FontSize="10" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>

    </DockPanel>
</UserControl>
