<Window x:Class="BIMPills.UI.ParameterExtractor.ExtractorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:params="clr-namespace:BIMPills.UI.Export.Parameters"
        Title="BIM Pills — Extractor de Parámetros"
        Width="960" Height="680"
        MinWidth="820" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Extractor de Parámetros"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ModelNameLabel"
                               Text="Modelo"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Extrae datos del elemento (coordenadas, categoría, nivel, ...) a parámetros del modelo"
                               FontSize="11"
                               Foreground="#86868B"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>

                        <Button x:Name="ApplyButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,0"
                                IsEnabled="False"
                                Click="Apply_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Aplicar extracción" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Panel -->
                <params:ParameterExtractorPanel x:Name="Panel"/>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
