<Window x:Class="BIMPills.UI.DataManager.GestionarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:keynotes="clr-namespace:BIMPills.UI.Keynotes"
        xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
        Title="BIM Pills — Gestionar"
        Width="960" Height="700"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20,16,20,14">

        <!-- Header card -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="20" Height="32" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Gestionar" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ModelNameLabel" Text="Modelo" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content card -->
        <Border Style="{StaticResource CardBorder}">
            <DockPanel>

                <!-- Footer — Cerrar left, actions right -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Content="Cerrar (ESC)"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                IsCancel="True"
                                Click="Close_Click"/>
                        <TextBlock x:Name="StatusLabel"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   FontSize="11" Foreground="#86868B"
                                   FontFamily="Segoe UI"
                                   Margin="12,0,0,0"/>

                        <Button x:Name="FooterImportButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,0"
                                Margin="8,0,0,0"
                                Click="Import_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2191;" FontSize="13" FontWeight="Bold"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Importar Excel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="FooterExportButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Padding="14,0"
                                IsEnabled="False"
                                Click="Export_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2193;" FontSize="13" FontWeight="Bold"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar Excel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Tab bar -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="14,0">
                        <Border x:Name="Tab0Border" Style="{StaticResource TabHeaderActive}"
                                MouseLeftButtonDown="Tab0_Click">
                            <TextBlock x:Name="Tab0Text" Style="{StaticResource TabHeaderTextActive}"
                                       Text="Tablas"/>
                        </Border>
                        <Border x:Name="Tab1Border" Style="{StaticResource TabHeader}"
                                MouseLeftButtonDown="Tab1_Click">
                            <TextBlock x:Name="Tab1Text" Style="{StaticResource TabHeaderText}"
                                       Text="Notas Clave"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tool header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="14,12">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ToolHeaderIconBorder" Width="30" Height="30" CornerRadius="7" Background="#E3F2FD"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <bimca:Icon x:Name="ToolHeaderIcon" Slug="table" Size="16"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ToolHeaderTitle" Text="Tablas de planificación" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="ToolHeaderSubtitle" Text="Exporta e importa datos de tablas de planificación al modelo"
                                       FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Content area -->
                <Grid>

                <!-- Tablas content (tab 0) -->
                <DockPanel x:Name="TablasContent">

                    <!-- Import notification bar (hidden by default) -->
                    <Border x:Name="ImportBar" DockPanel.Dock="Top"
                            Background="#E8F5E9" Padding="10,8"
                            BorderBrush="#C8E6C9" BorderThickness="0,0,0,1"
                            Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Aplicar al modelo"
                                    Height="28" Padding="14,0" Margin="8,0,0,0"
                                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                    Background="#2E7D32" Foreground="White"
                                    BorderBrush="#2E7D32" BorderThickness="1"
                                    Cursor="Hand"
                                    Click="Apply_Click"/>
                            <Button DockPanel.Dock="Right"
                                    Content="Descartar"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="28" Padding="10,0"
                                    Click="DiscardImport_Click"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="16" Height="16" Fill="#4CAF50" Margin="0,0,6,0"/>
                                <TextBlock Text="✓" Foreground="White" FontWeight="Bold" FontSize="10"
                                           Margin="-19,0,9,0" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ImportBarText"
                                           VerticalAlignment="Center"
                                           FontSize="11" Foreground="#2E7D32"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Export destination bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#F9F9FB" Padding="10,7"
                            BorderBrush="#F2F2F7" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="EXPORTAR A:" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="#86868B" FontFamily="Segoe UI"
                                       Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right"
                                    Content="Examinar..."
                                    Style="{StaticResource SecondaryButton}"
                                    Height="26" Padding="10,0" Margin="6,0,0,0"
                                    Click="BrowseExportFolder_Click"/>
                            <TextBox x:Name="ExportPathBox"
                                     Height="26"
                                     FontFamily="Segoe UI" FontSize="11"
                                     Padding="8,4" Background="White"
                                     BorderBrush="#D1D1D6" BorderThickness="1"
                                     IsReadOnly="True"/>
                        </DockPanel>
                    </Border>

                    <!-- 2-column layout -->
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" MinWidth="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: schedule list -->
                        <DockPanel Grid.Column="0" Margin="12,10,10,10">
                            <DockPanel DockPanel.Dock="Top" Margin="2,0,0,8">
                                <TextBlock Text="TABLAS DEL MODELO" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#86868B" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="SelectionCountText" DockPanel.Dock="Right"
                                           FontSize="10" Foreground="{StaticResource AccentBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <Button x:Name="SelectAllButton" DockPanel.Dock="Top"
                                    Content="Seleccionar todo"
                                    Style="{StaticResource TertiaryButton}"
                                    Height="26" FontSize="11" Margin="0,0,0,6"
                                    Click="SelectAll_Click"/>
                            <!-- Search -->
                            <TextBox x:Name="ScheduleSearchBox"
                                     DockPanel.Dock="Top"
                                     Style="{StaticResource BIMPillsTextBox}"
                                     Height="30" Margin="0,0,0,6"
                                     Tag="Buscar tabla..."
                                     TextChanged="ScheduleSearch_Changed"/>
                            <ListBox x:Name="ScheduleListBox"
                                     Style="{StaticResource BIMPillsListBox}"
                                     SelectionChanged="ScheduleList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Background="Transparent"
                                                            BorderBrush="#E5E5EA"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="10,9">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#FFF3EE"/>
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFCDB8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      Click="ScheduleCheckBox_Click"/>
                                            <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           FontFamily="Segoe UI"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontSize="10" Foreground="#86868B"
                                                           FontFamily="Segoe UI" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <!-- Row count badge -->
                                            <Border Grid.Column="2" Background="#F2F2F7"
                                                    CornerRadius="10" Padding="7,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RowCount}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="#86868B" FontFamily="Segoe UI"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <GridSplitter Grid.Column="1" Width="1"
                                      Background="#E5E5EA"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                        <!-- Right: empty state | preview area | diff area -->
                        <Grid Grid.Column="2">

                            <!-- Empty state (visible when no table selected) -->
                            <Border x:Name="EmptyState"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="52" Height="52" CornerRadius="13"
                                            Background="#F0F7FF" HorizontalAlignment="Center"
                                            Margin="0,0,0,14">
                                        <bimca:Icon Slug="table" Size="28"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Selecciona una tabla"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Elige una tabla de la lista para ver sus datos y exportar a Excel."
                                               FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" TextAlignment="Center"
                                               TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="240"/>
                                </StackPanel>
                            </Border>

                            <!-- Preview area (hidden by default, shown after selection) -->
                            <DockPanel x:Name="PreviewArea" Visibility="Collapsed" Margin="8,0,0,0">

                                <!-- Toolbar — legend only -->
                                <Border DockPanel.Dock="Top"
                                        BorderBrush="#F2F2F7" BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <DockPanel>
                                        <!-- Color legend -->
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,4,0">
                                            <Border Width="10" Height="10" CornerRadius="2"
                                                    Background="White" BorderBrush="#D1D1D6"
                                                    BorderThickness="1.5" Margin="0,0,4,0"/>
                                            <TextBlock Text="Editable" FontSize="10"
                                                       Foreground="#86868B" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Border Width="10" Height="10" CornerRadius="2"
                                                    Background="#FFF9C4" BorderBrush="#F0E68C"
                                                    BorderThickness="1.5" Margin="0,0,4,0"/>
                                            <TextBlock Text="Solo lectura" FontSize="10"
                                                       Foreground="#86868B" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Border Width="10" Height="10" CornerRadius="2"
                                                    Background="#E8F5E9" BorderBrush="#A5D6A7"
                                                    BorderThickness="1.5" Margin="0,0,4,0"/>
                                            <TextBlock Text="Modificado" FontSize="10"
                                                       Foreground="#86868B" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Data grid -->
                                <DataGrid x:Name="PreviewGrid"
                                          Style="{StaticResource BIMPillsDataGrid}"
                                          AutoGenerateColumns="True"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Extended"
                                          AutoGeneratingColumn="PreviewGrid_AutoGeneratingColumn"/>


                            </DockPanel>

                            <!-- Diff preview area (shown when import is pending) -->
                            <DockPanel x:Name="DiffArea" Visibility="Collapsed" Margin="8,0,0,0">

                                <!-- Diff header -->
                                <Border DockPanel.Dock="Top"
                                        BorderBrush="#F2F2F7" BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="28" Height="28" CornerRadius="6"
                                                    Background="#E8F5E9" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <bimca:Icon Slug="backspace" Size="14"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Vista previa de cambios" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                                                <TextBlock x:Name="DiffCountLabel" Text=""
                                                           FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Legend -->
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="0,0,4,0">
                                            <Border Width="10" Height="10" CornerRadius="2"
                                                    Background="#E8F5E9" BorderBrush="#A5D6A7"
                                                    BorderThickness="1.5" Margin="0,0,4,0"/>
                                            <TextBlock Text="Cambio pendiente" FontSize="10"
                                                       Foreground="#86868B" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Diff data grid -->
                                <DataGrid x:Name="DiffGrid"
                                          Style="{StaticResource BIMPillsDataGrid}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="TABLA" Binding="{Binding Tabla}"
                                                            Width="160" MinWidth="80"/>
                                        <DataGridTextColumn Header="ELEMENTO ID" Binding="{Binding ElementId}"
                                                            Width="100" MinWidth="80"/>
                                        <DataGridTextColumn Header="PARÁMETRO" Binding="{Binding Parametro}"
                                                            Width="180" MinWidth="100"/>
                                        <DataGridTextColumn Header="VALOR ACTUAL" Binding="{Binding ValorActual}"
                                                            Width="*" MinWidth="100"/>
                                        <DataGridTextColumn Header="NUEVO VALOR" Binding="{Binding NuevoValor}"
                                                            Width="*" MinWidth="100"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="#F1F8E9"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#DCEDC8"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#C5E1A5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>

                            </DockPanel>

                        </Grid>

                    </Grid>

                </DockPanel>

                <!-- Notas Clave content (tab 1) -->
                <keynotes:KeynotesPanel x:Name="KeynotesPanel" Visibility="Collapsed"/>

                <!-- Loading overlay -->
                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Panel.ZIndex="10">
                    <Border Background="#CCFFFFFF"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200" Height="3" Margin="0,0,0,14"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#E5E5EA" BorderThickness="0"/>
                        <TextBlock x:Name="LoadingText"
                                   Text="Cargando..."
                                   FontSize="13" FontWeight="Medium"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                </Grid>

            </DockPanel>
        </Border>

    </DockPanel>
</Window>
