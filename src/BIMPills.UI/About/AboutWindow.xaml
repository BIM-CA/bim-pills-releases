<Window x:Class="BIMPills.UI.About.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Acerca de"
        Width="440"
        SizeToContent="Height"
        MaxHeight="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="28,20,28,16">

        <!-- Logo BIMPills (PNG real) -->
        <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
               Width="44" Height="70"
               Margin="0,0,0,8"
               HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Nombre del plugin -->
        <TextBlock Text="BIMPills"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="Segoe UI"/>

        <!-- Descripción breve -->
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,14"
                   FontFamily="Segoe UI"/>

        <!-- Tarjeta de información -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Versión"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,10"/>
                <TextBlock x:Name="VersionText"
                           Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Desarrollador"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,10"/>
                <TextBlock x:Name="DeveloperText"
                           Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Empresa"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="CompanyText"
                           Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource BodyText}"/>
            </Grid>
        </Border>

        <!-- Sitio web + Soporte (lado a lado) -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Enlace al sitio web -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Visitar sitio web"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="WebsiteText"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonUp="Website_Click"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Soporte -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Soporte técnico"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SupportEmailText"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonUp="SupportEmail_Click"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Licencia -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Plan"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,6"/>
                <TextBlock x:Name="LicensePlanText"
                           Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Estado"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,6"/>
                <TextBlock x:Name="LicenseStatusText"
                           Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text=" "
                           Margin="0,0,20,0"/>
                <Button x:Name="BtnActivateLicense"
                        Grid.Row="2" Grid.Column="1"
                        Content="Activar licencia"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left"
                        Padding="12,4"
                        FontSize="11"
                        Click="ActivateLicense_Click"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Copyright -->
        <TextBlock x:Name="CopyrightText"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"
                   FontFamily="Segoe UI"/>

        <!-- ESC cierra la ventana (botón invisible, IsCancel) -->
        <Button IsCancel="True" Visibility="Collapsed" Click="CloseButton_Click"/>

    </StackPanel>
</Window>
