<Window x:Class="BIMPills.UI.About.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Acerca de"
        Width="450" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- Encabezado con identidad de marca -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Padding="0,32,0,28">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="BIM Pills"
                           FontSize="28" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
                <TextBlock x:Name="DescriptionText"
                           FontSize="12"
                           Foreground="#BBBBBB"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"
                           FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Pie de pagina -->
        <StackPanel DockPanel.Dock="Bottom" Margin="24,0,24,20">
            <TextBlock x:Name="CopyrightText"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       FontFamily="Segoe UI"/>
            <Button Content="Cerrar"
                    Style="{StaticResource PrimaryButton}"
                    Width="120"
                    HorizontalAlignment="Center"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Contenido central -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Margin="24,20,24,12">
            <StackPanel>

                <!-- Tarjeta de informacion -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Version -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Version:"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,16,8"/>
                        <TextBlock x:Name="VersionText"
                                   Grid.Row="0" Grid.Column="1"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,0,0,8"/>

                        <!-- Desarrollador -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Desarrollador:"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,16,8"/>
                        <TextBlock x:Name="DeveloperText"
                                   Grid.Row="1" Grid.Column="1"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,0,0,8"/>

                        <!-- Empresa -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Empresa:"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,16,0"/>
                        <TextBlock x:Name="CompanyText"
                                   Grid.Row="2" Grid.Column="1"
                                   Style="{StaticResource BodyText}"/>
                    </Grid>
                </Border>

                <!-- Enlace al sitio web -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Visitar sitio web"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryAccentBrush}"
                                   HorizontalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="Website_Click"
                                   TextDecorations="Underline"
                                   FontFamily="Segoe UI"/>
                        <TextBlock x:Name="WebsiteText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
