<Window x:Class="BIMPills.UI.About.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIMPills — Acerca de"
        Width="440"
        SizeToContent="Height"
        MaxHeight="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="28,20,28,16">

        <!-- Logo BIMPills (PNG real) -->
        <Image Source="/BIMPills.UI;component/Resources/pill-icon.png"
               Width="44" Height="70"
               Margin="0,0,0,8"
               HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Nombre del plugin -->
        <TextBlock Text="BIMPills"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="Segoe UI"/>

        <!-- Descripción breve -->
        <TextBlock x:Name="DescriptionText"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,14"
                   FontFamily="Segoe UI"/>

        <!-- Tarjeta de información -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Versión"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,10"/>
                <TextBlock x:Name="VersionText"
                           Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Desarrollador"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,10"/>
                <TextBlock x:Name="DeveloperText"
                           Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource BodyText}"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Empresa"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="CompanyText"
                           Grid.Row="2" Grid.Column="1"
                           Style="{StaticResource BodyText}"/>
            </Grid>
        </Border>

        <!-- Sitio web + Soporte (lado a lado) -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Enlace al sitio web -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Visitar sitio web"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="WebsiteText"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonUp="Website_Click"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Soporte -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Soporte técnico"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                               FontFamily="Segoe UI"/>
                    <TextBlock x:Name="SupportEmailText"
                               FontSize="13"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonUp="SupportEmail_Click"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Licencia -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
            <StackPanel>

                <!-- Encabezado: título + badge de estado -->
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="LICENCIA"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Border x:Name="LicenseStatusBadge"
                            HorizontalAlignment="Right"
                            CornerRadius="10"
                            Padding="10,3">
                        <TextBlock x:Name="LicenseStatusText"
                                   FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                    </Border>
                </Grid>

                <!-- Titular + plan -->
                <TextBlock x:Name="LicenseHolderText"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,2"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="LicensePlanText"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="LicenseExpiryText"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,10"
                           Visibility="Collapsed"/>

                <!-- Sin licencia — enlace a tienda -->
                <StackPanel x:Name="PanelGetLicense"
                            Orientation="Horizontal"
                            Margin="0,2,0,10"
                            Visibility="Collapsed">
                    <TextBlock Text="¿No tienes licencia?  "
                               FontSize="12"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Obtén una en bim-ca.com"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource AccentBrush}"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               MouseLeftButtonUp="GetLicense_Click"/>
                </StackPanel>

                <!-- Separador -->
                <Border x:Name="LicenseButtonSeparator"
                        Height="1"
                        Background="{StaticResource SeparatorBrush}"
                        Margin="0,0,0,10"
                        Visibility="Collapsed"/>

                <!-- Acciones (alineadas a la derecha) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnActivateLicense"
                            Content="Activar licencia"
                            Style="{StaticResource PrimaryButton}"
                            Height="30" FontSize="11"
                            Padding="14,0"
                            Margin="0,0,8,0"
                            Click="ActivateLicense_Click"
                            Visibility="Collapsed"/>
                    <TextBlock x:Name="BtnRenewLicense"
                               Text="Renovar suscripción →"
                               FontSize="12"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               MouseLeftButtonUp="RenewLicense_Click"
                               Visibility="Collapsed"/>
                    <Button x:Name="BtnDeactivateLicense"
                            Content="Desactivar equipo"
                            Style="{StaticResource TertiaryButton}"
                            Height="30" FontSize="11"
                            Padding="14,0"
                            Click="DeactivateLicense_Click"
                            Visibility="Collapsed"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Copyright -->
        <TextBlock x:Name="CopyrightText"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"
                   FontFamily="Segoe UI"/>

        <!-- ESC cierra la ventana (botón invisible, IsCancel) -->
        <Button IsCancel="True" Visibility="Collapsed" Click="CloseButton_Click"/>

    </StackPanel>
</Window>
