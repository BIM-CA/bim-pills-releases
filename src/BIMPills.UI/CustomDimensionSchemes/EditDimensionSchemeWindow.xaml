<Window x:Class="BIMPills.UI.CustomDimensionSchemes.EditDimensionSchemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIMPills.UI.CustomDimensionSchemes"
        Title="BIMPills — Editar Esquema de Cotas"
        Width="700" Height="600"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Editar Esquema"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,16"
                   FontFamily="Segoe UI"/>

        <!-- Content -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,12">

                    <!-- Name field -->
                    <TextBlock Text="Nombre del Esquema" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameTextBox" Style="{StaticResource InputTextBox}"
                             Margin="0,0,0,14" MinHeight="36"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                    <!-- Description field -->
                    <TextBlock Text="Descripción" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="DescriptionTextBox" Style="{StaticResource InputTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="60" MaxHeight="100"
                             Margin="0,0,0,14"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA"
                             Padding="10,8"/>

                    <!-- Applicable element types -->
                    <TextBlock Text="Tipos de Elementos" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="ElementTypesPanel" Orientation="Vertical" Margin="0,0,0,14">
                        <!-- Checkboxes will be added programmatically -->
                    </StackPanel>

                    <!-- Rules section -->
                    <TextBlock Text="Reglas de Dimensionamiento" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <ListBox x:Name="RulesList" MinHeight="150" MaxHeight="250"
                             Background="White" BorderThickness="1" BorderBrush="#E5E5EA">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ElementProperty}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding DimensionFormat}"
                                                       FontSize="11" Foreground="#86868B" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsActive}"
                                                  VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click"/>
                <Button Content="Guardar"
                        Style="{StaticResource PrimaryButton}"
                        Width="100"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>

    </DockPanel>
</Window>
