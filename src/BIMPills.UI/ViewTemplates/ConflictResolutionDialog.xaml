<Window x:Class="BIMPills.UI.ViewTemplates.ConflictResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Resolver conflictos"
        Width="580" Height="460"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="16,14,16,14">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#FFF8E1" CornerRadius="8"
                BorderBrush="#FFE082" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                           FontSize="18" Foreground="#F57F17"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#E65100" FontFamily="Segoe UI"/>
                    <TextBlock Text="Elige la acci&#243;n para cada plantilla con conflicto."
                               FontSize="11" Foreground="#BF360C" FontFamily="Segoe UI"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Bulk action bar -->
        <Border DockPanel.Dock="Top"
                Background="White" CornerRadius="6"
                BorderBrush="#E5E5EA" BorderThickness="1"
                Padding="10,8" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Aplicar a todos:" FontSize="11" FontFamily="Segoe UI"
                           Foreground="#555" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Left"
                        Content="Reemplazar todo" FontSize="11" FontFamily="Segoe UI"
                        Height="26" Padding="10,0" Margin="0,0,6,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BulkReplace_Click"/>
                <Button DockPanel.Dock="Left"
                        Content="Omitir todo" FontSize="11" FontFamily="Segoe UI"
                        Height="26" Padding="10,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BulkSkip_Click"/>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="BulkSummary"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="#86868B"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="0,10,0,0" Margin="0,8,0,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Width="100" IsCancel="True"
                        Click="Cancel_Click"/>
                <Button DockPanel.Dock="Right" Content="Continuar transferencia"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,0" IsDefault="True"
                        Click="Confirm_Click"/>
            </DockPanel>
        </Border>

        <!-- Conflict list -->
        <Border Background="White" CornerRadius="6"
                BorderBrush="#E5E5EA" BorderThickness="1">
            <DataGrid x:Name="ConflictGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0F0F0"
                      Background="White"
                      BorderThickness="0"
                      RowHeight="32"
                      ColumnHeaderHeight="30"
                      FontFamily="Segoe UI" FontSize="11">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Foreground" Value="#555"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#E5E5EA"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F8FB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- Nombre -->
                    <DataGridTextColumn Header="Plantilla" Binding="{Binding Name}"
                                        Width="*" IsReadOnly="True" MinWidth="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,6,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tipo -->
                    <DataGridTextColumn Header="Tipo" Binding="{Binding ViewType}"
                                        Width="110" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#86868B"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Acción -->
                    <DataGridTemplateColumn Header="Acci&#243;n" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          Margin="4,3" Padding="6,2"
                                          FontSize="11" FontFamily="Segoe UI"
                                          BorderBrush="#D1D1D6"
                                          SelectionChanged="ActionCombo_Changed">
                                    <ComboBoxItem Content="Reemplazar" Tag="Replace"/>
                                    <ComboBoxItem Content="Omitir" Tag="Skip"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </DockPanel>
</Window>
