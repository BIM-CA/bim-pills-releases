<UserControl x:Class="BIMPills.UI.ViewTemplates.ViewTemplateTransferPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:bimca="clr-namespace:BIMPills.UI.Resources"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Source document selector -->
        <Border DockPanel.Dock="Top"
                Background="#F8F9FA" Padding="14,10"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Documento fuente:"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="SourceDocCombo"
                          Style="{StaticResource BIMPillsComboBox}"
                          SelectionChanged="SourceDoc_Changed">
                    <ComboBox.Tag>Seleccionar proyecto abierto...</ComboBox.Tag>
                </ComboBox>
            </DockPanel>
        </Border>

        <!-- Conflict resolution + status bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Conflictos:" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ConflictCombo"
                              Style="{StaticResource BIMPillsComboBox}"
                              Width="160">
                        <ComboBoxItem Content="Reemplazar todo" Tag="Replace" IsSelected="True"/>
                        <ComboBoxItem Content="Omitir todo" Tag="Skip"/>
                        <ComboBoxItem Content="Elegir individualmente..." Tag="Individual"/>
                    </ComboBox>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Selecciona un documento fuente"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main 2-column layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: template list -->
            <DockPanel Grid.Column="0" Margin="12,10,10,10">

                <!-- Search + Select all -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="Todos" Style="{StaticResource TertiaryButton}"
                            Padding="8,4" FontSize="11" Margin="6,0,0,0"
                            Click="SelectAll_Click"/>
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource BIMPillsTextBox}"
                             Height="28" FontSize="11"
                             Tag="Buscar plantilla..."
                             TextChanged="Search_TextChanged"/>
                </DockPanel>

                <!-- Summary -->
                <Border DockPanel.Dock="Top" Background="#F8F9FA" CornerRadius="4"
                        Padding="10,5" Margin="0,0,0,6">
                    <TextBlock x:Name="SelectionSummary"
                               Text="0 de 0 seleccionadas"
                               FontSize="10" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <!-- Template list -->
                <ListBox x:Name="TemplateListBox"
                         Style="{StaticResource BIMPillsListBox}"
                         SelectionChanged="TemplateList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                BorderBrush="#E5E5EA"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,7">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#F5F5F7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF3FF"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#C5CAE9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                          Click="TemplateCheckBox_Click"/>
                                <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontFamily="Segoe UI"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ViewType}"
                                               FontSize="10" Foreground="#86868B"
                                               FontFamily="Segoe UI" Margin="0,1,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#F2F2F7"
                                        CornerRadius="10" Padding="7,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FilterCount, StringFormat={}{0} filtros}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#86868B" FontFamily="Segoe UI"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="1"
                          Background="#E5E5EA"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Right: detail preview -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <Border x:Name="DetailEmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="12"
                                Background="#F0F7FF" HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <bimca:Icon Slug="view-eye" Size="26"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Selecciona una plantilla"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Elige una plantilla de la lista para ver sus par&#225;metros."
                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="220"/>
                    </StackPanel>
                </Border>

                <!-- Detail panel -->
                <DockPanel x:Name="DetailPanel" Visibility="Collapsed">

                    <!-- Header: name + type + view count -->
                    <Border DockPanel.Dock="Top"
                            Padding="12,10,12,8"
                            BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="DetailName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Segoe UI"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="#E3F2FD" CornerRadius="4" Padding="6,2">
                                        <TextBlock x:Name="DetailViewType"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#1565C0" FontFamily="Segoe UI"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="AssignedViewCount"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       FontSize="10" FontFamily="Segoe UI"
                                       Foreground="#86868B"/>
                        </Grid>
                    </Border>

                    <!-- Parameters DataGrid -->
                    <DataGrid x:Name="ParamsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="27"
                              ColumnHeaderHeight="30"
                              FontFamily="Segoe UI"
                              FontSize="11">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="BorderBrush" Value="#E5E5EA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Include}" Value="False">
                                        <Setter Property="Opacity" Value="0.38"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>

                            <!-- Parámetro -->
                            <DataGridTextColumn Binding="{Binding Name}"
                                                Header="Par&#225;metro"
                                                Width="190" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,0,4,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Valor -->
                            <DataGridTemplateColumn Header="Valor" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,0,4,0">
                                            <!-- Simple editable value -->
                                            <TextBox x:Name="TbSimple"
                                                     Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     VerticalAlignment="Center"
                                                     FontSize="11" FontFamily="Segoe UI"
                                                     Foreground="#1565C0"/>
                                            <!-- Complex "Editar..." -->
                                            <TextBlock x:Name="TbComplex"
                                                       Text="Editar..."
                                                       Foreground="#AEAEB2"
                                                       FontStyle="Italic"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       Visibility="Collapsed"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsComplex}" Value="True">
                                                <Setter TargetName="TbSimple"   Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="TbComplex"  Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Incluir -->
                            <DataGridCheckBoxColumn
                                Binding="{Binding Include, UpdateSourceTrigger=PropertyChanged}"
                                Header="Incluir"
                                Width="62"
                                IsReadOnly="False">
                                <DataGridCheckBoxColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.HeaderStyle>
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>

                <!-- Single-doc empty state -->
                <Border x:Name="SingleDocState" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="12"
                                Background="#FFF3E0" HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <bimca:Icon Slug="3d-cube" Size="26"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Solo hay un proyecto abierto"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Abre otro proyecto en Revit para transferir plantillas de vista entre documentos."
                                   FontSize="11" Foreground="#86868B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0" MaxWidth="260"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>

    </DockPanel>

</UserControl>
