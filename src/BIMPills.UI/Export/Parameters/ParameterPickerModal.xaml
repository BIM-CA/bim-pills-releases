<Window x:Class="BIMPills.UI.Export.Parameters.ParameterPickerModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BIMPills.UI.ParameterExtractor"
        Title="Agregar fuentes de extracción"
        Width="860" Height="640"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        Background="White"
        ShowInTaskbar="False"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- scope bar -->
            <RowDefinition Height="*"/>     <!-- content -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Scope bar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#FAFAFC"
                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                Padding="14,9">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Alcance:"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="#86868B"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <RadioButton x:Name="ScopeSelectionRadio"
                             Content="Selección actual"
                             GroupName="PickerScope"
                             IsChecked="True"
                             FontSize="11" FontFamily="Segoe UI"
                             VerticalAlignment="Center"
                             Margin="0,0,16,0"/>
                <RadioButton x:Name="ScopeModelRadio"
                             Content="Todo el modelo"
                             GroupName="PickerScope"
                             FontSize="11" FontFamily="Segoe UI"
                             VerticalAlignment="Center"
                             Margin="0,0,16,0"/>
                <RadioButton x:Name="ScopeViewRadio"
                             Content="Vista activa"
                             GroupName="PickerScope"
                             FontSize="11" FontFamily="Segoe UI"
                             VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Content ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="160"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Categorías ════════════════════════════════════════ -->
            <DockPanel Grid.Column="0">

                <!-- Column header -->
                <Border DockPanel.Dock="Top"
                        Background="#F4F4F7"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <TextBlock Text="CATEGORÍAS"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#1565C0"/>
                </Border>

                <!-- Search -->
                <Border DockPanel.Dock="Top"
                        Padding="8,6"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                    <TextBox x:Name="CategorySearch"
                             Style="{StaticResource BIMPillsTextBox}"
                             Height="28" FontSize="11"
                             Tag="Buscar categoría..."
                             TextChanged="CategorySearch_TextChanged"/>
                </Border>

                <!-- "Todas" toggle -->
                <Border DockPanel.Dock="Top"
                        Padding="12,0"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Background="#FAFAFC">
                    <CheckBox x:Name="AllCategoriesCheck"
                              Content="Todas las categorías"
                              Height="30"
                              FontSize="11" FontWeight="SemiBold"
                              VerticalContentAlignment="Center"
                              Click="AllCategories_Click"/>
                </Border>

                <!-- Category list -->
                <ListBox x:Name="CategoryList"
                         BorderThickness="0"
                         Background="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent">
                                            <ContentPresenter/>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="Bd"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#EEF4FD" Duration="0:0:0.1"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <CheckBox IsChecked="{Binding IsChecked}"
                                          Content="{Binding Name}"
                                          Height="28"
                                          FontSize="11"
                                          VerticalContentAlignment="Center"
                                          Checked="Category_CheckChanged"
                                          Unchecked="Category_CheckChanged"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Fill="#E5E5EA"/>

            <!-- ═══ RIGHT: Fuentes ═══════════════════════════════════════════ -->
            <DockPanel Grid.Column="2">

                <!-- Column header -->
                <Border DockPanel.Dock="Top"
                        Background="#F4F4F7"
                        BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <CheckBox x:Name="HideUncheckedCheck"
                                  DockPanel.Dock="Right"
                                  Content="Ocultar no marcados"
                                  FontSize="10" FontFamily="Segoe UI"
                                  Foreground="#86868B"
                                  VerticalAlignment="Center"
                                  ToolTip="Mostrar solo las fuentes seleccionadas"
                                  Checked="HideUnchecked_Changed"
                                  Unchecked="HideUnchecked_Changed"/>
                        <TextBlock Text="FUENTES DISPONIBLES"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#1565C0"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Scrollable source list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- ── Grupo: Coordenadas ──────────────────────────── -->
                        <Border Background="#F4F4F7"
                                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                                Padding="12,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📍" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Coordenadas"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#3C3C43" VerticalAlignment="Center"/>
                                <TextBlock Text="  X · Y · Z · Latitud · Longitud"
                                           FontSize="10" Foreground="#86868B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="CoordList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MinHeight="36"
                                            Padding="16,0,14,0"
                                            BorderBrush="#F0F0F5" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F5F8FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── Grupo: Identificadores ─────────────────────── -->
                        <Border Background="#F4F4F7"
                                BorderBrush="#E5E5EA" BorderThickness="0,1,0,1"
                                Margin="0,6,0,0"
                                Padding="12,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏷" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Identificadores"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#3C3C43" VerticalAlignment="Center"/>
                                <TextBlock Text="  Categoría · Familia · Tipo · Nivel · Id"
                                           FontSize="10" Foreground="#86868B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="IdentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MinHeight="36"
                                            Padding="16,0,14,0"
                                            BorderBrush="#F0F0F5" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F5F8FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── Grupo: Parámetros del elemento ─────────────── -->
                        <Border Background="#F4F4F7"
                                BorderBrush="#E5E5EA" BorderThickness="0,1,0,1"
                                Margin="0,6,0,0"
                                Padding="12,7">
                            <DockPanel>
                                <TextBlock x:Name="ParamCountText"
                                           DockPanel.Dock="Right"
                                           FontSize="10" Foreground="#AEAEB2"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Parámetros del elemento"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#3C3C43" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Búsqueda de parámetros -->
                        <Border Padding="8,5"
                                BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                            <TextBox x:Name="ParamSearch"
                                     Style="{StaticResource BIMPillsTextBox}"
                                     Height="26" FontSize="11"
                                     Tag="Buscar parámetro..."
                                     TextChanged="ParamSearch_TextChanged"/></Border>

                        <ItemsControl x:Name="ElementParamList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MinHeight="36"
                                            Padding="16,0,14,0"
                                            BorderBrush="#F0F0F5" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F5F8FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="ElementParamsEmpty"
                                Padding="16,12" Visibility="Visible">
                            <TextBlock Text="Sin parámetros disponibles — se cargan desde Revit al seleccionar elementos"
                                       FontSize="10" Foreground="#AEAEB2"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- ── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#FAFAFC"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left"
                        Content="Cancelar"
                        Style="{StaticResource PrimaryButton}"
                        Width="100" Height="30" FontSize="11"
                        Click="Cancel_Click"/>
                <Button x:Name="ConfirmButton"
                        DockPanel.Dock="Right"
                        Content="Agregar →"
                        Style="{StaticResource SecondaryButton}"
                        Width="108" Height="30" FontSize="11"
                        IsEnabled="False"
                        Click="Confirm_Click"/>
                <TextBlock x:Name="SelectionCountText"
                           Text="0 fuentes seleccionadas"
                           FontSize="11"
                           Foreground="#86868B"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="14,0,0,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
