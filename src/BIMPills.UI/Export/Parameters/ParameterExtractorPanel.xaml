<UserControl x:Class="BIMPills.UI.Export.Parameters.ParameterExtractorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BIMPills.UI.Export.Parameters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="WizardStepBadge" TargetType="Border">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="CornerRadius" Value="9"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Style>

            <!-- TreeView item: collapsed by default, no selection highlight -->
            <Style x:Key="ExtractorTreeItem" TargetType="TreeViewItem">
                <Setter Property="IsExpanded" Value="False"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="2,1"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- Checkbox in filter tree: category=bold-blue, family=medium, type=normal -->
            <Style x:Key="FilterCheckBox" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Margin" Value="0,1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCategory}" Value="True">
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{StaticResource HeadingAccentBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsFamily}" Value="True">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{StaticResource FamilyTextBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Checkbox in param tree: SemiBold blue for group nodes -->
            <Style x:Key="TreeCheckBox" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{StaticResource HeadingAccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Circular info button — same as ModelAuditWindow -->
            <Style x:Key="InfoCircleButton" TargetType="Button">
                <Setter Property="Width" Value="20"/>
                <Setter Property="Height" Value="20"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="InfoBorder"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    Background="{StaticResource InfoPanelBorderBrush}"
                                    BorderThickness="0">
                                <TextBlock Text="i"
                                           FontSize="11" FontWeight="SemiBold"
                                           FontFamily="Georgia" FontStyle="Italic"
                                           Foreground="{StaticResource HeadingAccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InfoBorder" Property="Background"
                                            Value="{StaticResource HeadingAccentBrush}"/>
                                    <Setter TargetName="InfoBorder" Property="TextBlock.Foreground"
                                            Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- ── Barra de perfiles ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SectionHeaderBrush}"
                BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1"
                Padding="12,7">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="SavePresetBtn" Content="Guardar"
                            Style="{StaticResource TertiaryButton}"
                            Padding="10,4" Height="28" MinWidth="0" FontSize="11"
                            Margin="0,0,4,0"
                            Click="SavePreset_Click"/>
                    <Button x:Name="DeletePresetBtn" Content="Eliminar"
                            Style="{StaticResource TertiaryButton}"
                            Padding="10,4" Height="28" MinWidth="0" FontSize="11"
                            IsEnabled="False"
                            Click="DeletePreset_Click"/>
                </StackPanel>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="Perfil:"
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PresetCombo"
                              Style="{StaticResource BIMPillsComboBox}"
                              Height="28" FontSize="11"
                              SelectionChanged="Preset_Changed"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- ── Asistente de pasos ─────────────────────────────────────────── -->
        <TabControl x:Name="WizardTabs"
                    Style="{StaticResource BIMPillsTabControl}"
                    SelectionChanged="WizardTabs_SelectionChanged">

            <!-- ── Paso 1: Seleccionar ──────────────────────────────────── -->
            <TabItem Style="{StaticResource BIMPillsTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource WizardStepBadge}" Margin="0,0,6,0">
                            <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="Seleccionar" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="16,8,16,8">

                    <!-- Scope bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource AlternateRowBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Ámbito:"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton x:Name="ScopeModel"
                                         Content="Modelo completo"
                                         FontSize="12" FontFamily="Segoe UI"
                                         IsChecked="True"
                                         Checked="ScopeModel_Checked"
                                         Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <RadioButton x:Name="ScopeView"
                                         Content="Vista activa"
                                         FontSize="12" FontFamily="Segoe UI"
                                         Checked="ScopeView_Checked"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Scope info text -->
                    <TextBlock DockPanel.Dock="Top"
                               x:Name="SelectionInfoText"
                               Text=""
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Split: categories (left) | param tree (right) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" MinWidth="190"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: category filter -->
                        <DockPanel Grid.Column="0">

                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SectionHeaderBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1,1,1,0"
                                    CornerRadius="6,6,0,0"
                                    Padding="8,5">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="TODOS"
                                                ToolTip="Seleccionar todos"
                                                Style="{StaticResource CompactButton}"
                                                Click="SelectAllFilter_Click"/>
                                        <Button Content="NINGUNO"
                                                ToolTip="Limpiar selección"
                                                Style="{StaticResource CompactButton}"
                                                Margin="3,0,0,0"
                                                Click="ClearAllFilter_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="FILTRO DE ELEMENTOS"
                                               FontSize="10" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource HeadingAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>

                            <!-- Category → Family → Type filter tree -->
                            <TreeView x:Name="FilterTree"
                                      BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1,0,1,1"
                                      Background="{StaticResource WhiteBrush}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpandedByDefault}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="1,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <CheckBox Style="{StaticResource FilterCheckBox}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                                  IsThreeState="False"
                                                  Content="{Binding Label}"
                                                  Checked="FilterNode_CheckChanged"
                                                  Unchecked="FilterNode_CheckChanged"/>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                        </DockPanel>

                        <!-- splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource SeparatorBrush}"
                                      BorderBrush="Transparent" BorderThickness="1,0"/>

                        <!-- RIGHT: parameter tree -->
                        <DockPanel Grid.Column="2">

                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SectionHeaderBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1,1,1,0"
                                    CornerRadius="6,6,0,0"
                                    Padding="8,5">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="TODOS"
                                                ToolTip="Seleccionar todos los parámetros"
                                                Style="{StaticResource CompactButton}"
                                                Click="SelectAll_Click"/>
                                        <Button Content="NINGUNO"
                                                ToolTip="Limpiar selección de parámetros"
                                                Style="{StaticResource CompactButton}"
                                                Margin="3,0,0,0"
                                                Click="ClearAll_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="PARÁMETROS A EXTRAER"
                                               FontSize="10" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource HeadingAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>

                            <TreeView x:Name="ParamTree"
                                      BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1,0,1,1"
                                      Background="{StaticResource WhiteBrush}"
                                      ItemContainerStyle="{StaticResource ExtractorTreeItem}">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox Style="{StaticResource TreeCheckBox}"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay,
                                                                  UpdateSourceTrigger=PropertyChanged}"
                                                      IsThreeState="False"
                                                      Content="{Binding Label}"
                                                      Checked="TreeNode_CheckChanged"
                                                      Unchecked="TreeNode_CheckChanged"/>
                                            <!-- Info button — only visible on the geo group node -->
                                            <Button Style="{StaticResource InfoCircleButton}"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    ToolTip="¿Qué son las Coordenadas Geográficas BIM Pills?"
                                                    Visibility="{Binding IsGeoGroup, Converter={StaticResource BoolToVis}}"
                                                    Click="GeoInfo_Click"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                        </DockPanel>

                    </Grid>

                </DockPanel>
            </TabItem>

            <!-- ── Paso 2: Configurar parámetros ────────────────────────── -->
            <TabItem Style="{StaticResource BIMPillsTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource WizardStepBadge}" Margin="0,0,6,0">
                            <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="Configurar" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="16,8,16,8">

                    <!-- Units / Decimals bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource AlternateRowBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Unidades coords.:"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="UnitsCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Width="120" Height="28" FontSize="11"/>
                            <TextBlock Text="Decimales:"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="16,0,6,0"/>
                            <ComboBox x:Name="DecimalsCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Width="60" Height="28" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Scope summary: which categories will receive the parameters -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource SectionHeaderBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6" Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Categorías afectadas:"
                                       FontSize="11" FontFamily="Segoe UI"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ScopeCategoriesText"
                                       Text="Todas"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </DockPanel>
                    </Border>

                    <!-- Geo conversion settings — only visible when Lat/Lon rows are selected -->
                    <Border x:Name="GeoSettingsPanel"
                            DockPanel.Dock="Top"
                            Visibility="Collapsed"
                            Background="{StaticResource InfoPanelBackgroundBrush}"
                            BorderBrush="{StaticResource InfoPanelBorderBrush}" BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,10">
                        <DockPanel VerticalAlignment="Center">

                            <!-- Info button docked right -->
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource InfoCircleButton}"
                                    ToolTip="¿Qué son las Coordenadas Geográficas BIM Pills?"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    Click="GeoInfo_Click"/>

                            <!-- Label + radios wrap -->
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="Conversión geográfica:"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource HeadingAccentBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <RadioButton x:Name="GeoMethodRevit"
                                             Content="Revit ProjectLocation"
                                             FontSize="12" FontFamily="Segoe UI"
                                             GroupName="GeoMethod" IsChecked="True"
                                             Checked="GeoMethod_Changed"
                                             Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <RadioButton x:Name="GeoMethodUtm"
                                             Content="UTM manual"
                                             FontSize="12" FontFamily="Segoe UI"
                                             GroupName="GeoMethod"
                                             Checked="GeoMethod_Changed"
                                             Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <!-- UTM zone + hemisphere — only shown when UTM selected -->
                                <StackPanel x:Name="UtmSettingsPanel"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Zona:"
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="UtmZoneBox"
                                             Text="19"
                                             FontSize="12" FontFamily="Segoe UI"
                                             Width="44" Height="26"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Center"
                                             Margin="0,0,12,0"/>
                                    <RadioButton x:Name="UtmHemiNorth"
                                                 Content="Norte"
                                                 FontSize="12" FontFamily="Segoe UI"
                                                 GroupName="UtmHemi"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="UtmHemiSouth"
                                                 Content="Sur"
                                                 FontSize="12" FontFamily="Segoe UI"
                                                 GroupName="UtmHemi"
                                                 IsChecked="True"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <!-- Empty state overlay -->
                    <TextBlock x:Name="EmptyLabel"
                               DockPanel.Dock="Top"
                               Text="No hay parámetros seleccionados. Vuelve al Paso 1 y selecciona datos."
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0"
                               Visibility="Visible"/>

                    <!-- DataGrid with editable param names -->
                    <DataGrid x:Name="ParamGrid"
                              Style="{StaticResource BIMPillsDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionUnit="FullRow"
                              Visibility="Collapsed">
                        <!-- Highlight geo rows (Lat/Lon) with blue tint matching GeoSettingsPanel -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="10,0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGeoRow}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource InfoPanelBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource HeadingAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Nombre del parámetro"
                                                Binding="{Binding ParamName, UpdateSourceTrigger=LostFocus}"
                                                Width="*" MinWidth="160"/>

                            <DataGridTextColumn Header="Origen / Fuente"
                                                Binding="{Binding SourceLabel}"
                                                IsReadOnly="True"
                                                Width="200" MinWidth="150"/>

                            <DataGridComboBoxColumn Header="Tipo"
                                                    SelectedItemBinding="{Binding DataType,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{x:Static local:ParameterExtractorPanel.AllDataTypes}"
                                                    Width="90" MinWidth="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
