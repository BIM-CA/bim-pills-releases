<UserControl x:Class="BIMPills.UI.Export.Sheets.ExportSheetsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Token button style -->
            <Style x:Key="TokenButton" TargetType="Button">
                <Setter Property="Background" Value="#F0F0F0"/>
                <Setter Property="Foreground" Value="#212B37"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Collapsible section expander style -->
            <Style x:Key="SectionExpander" TargetType="Expander">
                <Setter Property="Foreground" Value="#1565C0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="BorderBrush" Value="#E5E5EA"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="0,0,0,8"/>
            </Style>

            <!-- Wizard step badge style -->
            <Style x:Key="WizardStepBadge" TargetType="Border">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="CornerRadius" Value="9"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Status bar (no buttons — export moved to ExportarWindow footer) -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E5E5EA" BorderThickness="0,1,0,0"
                Padding="14,10">
            <TextBlock x:Name="StatusText"
                       Text="0 items seleccionados"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Tabbed wizard content + progress overlay wrapper -->
        <Grid>

        <TabControl x:Name="WizardTabs"
                    Style="{StaticResource BIMPillsTabControl}"
                    Margin="14,10,14,0"
                    SelectionChanged="WizardTabs_SelectionChanged">

            <!-- ═══════════════ Tab 1: Selección ═══════════════ -->
            <TabItem Style="{StaticResource BIMPillsTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Badge1" Style="{StaticResource WizardStepBadge}" Margin="0,0,6,0">
                            <TextBlock x:Name="BadgeText1" Text="1"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="Selección" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="0,10,0,0">

                    <!-- Publication set bar (solo visible en paso 1) -->
                    <Border DockPanel.Dock="Top"
                            Background="#F8F9FA" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                            Padding="0,8" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button x:Name="SaveSetBtn" Content="Guardar" Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                        Click="SaveSet_Click"/>
                                <Button x:Name="SaveAsSetBtn" Content="Guardar como..." Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                        Click="SaveAsSet_Click"/>
                                <Button x:Name="RenameSetBtn" Content="Renombrar" Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11" Margin="0,0,4,0" IsEnabled="False"
                                        Click="RenameSet_Click"/>
                                <Button x:Name="DeleteSetBtn" Content="Eliminar" Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11" IsEnabled="False" Margin="0,0,6,0"
                                        Click="DeleteSet_Click"/>
                                <Separator Width="1" Background="#D0D0D8" Margin="0,2,6,2"/>
                                <Button x:Name="ExportSetBtn" Content="Exportar" Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11" Margin="0,0,4,0" IsEnabled="False"
                                        ToolTip="Exportar conjunto a archivo JSON"
                                        Click="ExportSet_Click"/>
                                <Button x:Name="ImportSetBtn" Content="Importar" Style="{StaticResource TertiaryButton}"
                                        Padding="10,4" FontSize="11"
                                        ToolTip="Importar conjunto desde archivo JSON"
                                        Click="ImportSet_Click"/>
                            </StackPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Conjunto:"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="PublicationSetCombo"
                                          Style="{StaticResource BIMPillsComboBox}"
                                          SelectionChanged="PublicationSet_Changed">
                                    <ComboBox.Tag>Seleccionar conjunto de publicación...</ComboBox.Tag>
                                </ComboBox>
                            </DockPanel>
                        </DockPanel>
                    </Border>

                    <!-- Search + actions bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <ComboBox x:Name="TypeFilterCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Width="130" Margin="0,0,8,0"
                                      SelectionChanged="TypeFilter_Changed">
                                <ComboBoxItem Content="Todos" Tag="All" IsSelected="True"/>
                                <ComboBoxItem Content="Planos" Tag="Sheet"/>
                                <ComboBoxItem Content="Plantas" Tag="FloorPlan"/>
                                <ComboBoxItem Content="Alzados" Tag="Elevation"/>
                                <ComboBoxItem Content="Secciones" Tag="Section"/>
                                <ComboBoxItem Content="Vistas 3D" Tag="ThreeDView"/>
                                <ComboBoxItem Content="Leyendas" Tag="Legend"/>
                                <ComboBoxItem Content="Diseño" Tag="DraftingView"/>
                            </ComboBox>
                            <Button Content="Seleccionar todo" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                    Click="SelectAll_Click"/>
                            <Button Content="Deseleccionar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11"
                                    Click="DeselectAll_Click"/>
                        </StackPanel>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource BIMPillsTextBox}"
                                 Padding="8,0"
                                 FontSize="12"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Tag>Buscar por número o nombre...</TextBox.Tag>
                        </TextBox>
                    </DockPanel>

                    <!-- Summary bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#F8F9FA" CornerRadius="6"
                            Padding="12,6" Margin="0,0,0,8">
                        <TextBlock x:Name="SelectionSummary"
                                   Text="0 de 0 items seleccionados"
                                   FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>

                    <!-- Sheets/Views DataGrid -->
                    <DataGrid x:Name="SheetsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              BorderBrush="#E5E5EA"
                              BorderThickness="1"
                              RowHeight="32"
                              ColumnHeaderHeight="34"
                              SelectionMode="Extended"
                              Background="White"
                              FontFamily="Segoe UI"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="☑" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Click="RowCheckBox_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Tipo" Width="90" IsReadOnly="True"
                                                       SortMemberPath="TypeLabel">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#F0F4F8" CornerRadius="4"
                                                Padding="6,2" Margin="2,0"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeLabel}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#455A64"
                                                       FontFamily="Segoe UI"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding SheetNumber}" Header="N°"
                                                Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Binding="{Binding DisplayName}" Header="Nombre"
                                                Width="170" IsReadOnly="True"/>
                            <DataGridTextColumn Binding="{Binding Revision}" Header="Rev."
                                                Width="50" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Disciplina" Width="100" IsReadOnly="True"
                                                       SortMemberPath="Discipline">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="DisciplineChip"
                                                Background="#E3F2FD" CornerRadius="4"
                                                Padding="6,2" Margin="2,0"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock x:Name="DisciplineLabel"
                                                       Text="{Binding Discipline}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#1565C0"
                                                       FontFamily="Segoe UI"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding DisciplineCategory}" Value="Estructura">
                                                <Setter TargetName="DisciplineChip" Property="Background" Value="#E8F5E9"/>
                                                <Setter TargetName="DisciplineLabel" Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DisciplineCategory}" Value="MEP">
                                                <Setter TargetName="DisciplineChip" Property="Background" Value="#FFF3E0"/>
                                                <Setter TargetName="DisciplineLabel" Property="Foreground" Value="#E65100"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DisciplineCategory}" Value="Other">
                                                <Setter TargetName="DisciplineChip" Property="Background" Value="#F3E5F5"/>
                                                <Setter TargetName="DisciplineLabel" Property="Foreground" Value="#6A1B9A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Discipline}" Value="">
                                                <Setter TargetName="DisciplineChip" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding DisplayFileName}" Header="Nombre de archivo"
                                                Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#86868B"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ Tab 2: Formato ═══════════════ -->
            <TabItem Style="{StaticResource BIMPillsTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Badge2" Style="{StaticResource WizardStepBadge}" Margin="0,0,6,0">
                            <TextBlock x:Name="BadgeText2" Text="2"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="Formato" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Export config preset bar -->
                <Border Grid.Row="0"
                        Background="#F8F9FA" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1"
                        Padding="0,8">
                    <DockPanel Margin="0,0,0,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button x:Name="SavePresetBtn" Content="Guardar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                    Click="SavePreset_Click"/>
                            <Button x:Name="SaveAsPresetBtn" Content="Guardar como..." Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                    Click="SaveAsPreset_Click"/>
                            <Button x:Name="RenamePresetBtn" Content="Renombrar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,4,0" IsEnabled="False"
                                    Click="RenamePreset_Click"/>
                            <Button x:Name="DeletePresetBtn" Content="Eliminar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,6,0" IsEnabled="False"
                                    Click="DeletePreset_Click"/>
                            <Separator Width="1" Background="#D0D0D8" Margin="0,2,6,2"/>
                            <Button x:Name="ExportPresetBtn" Content="Exportar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,4,0" IsEnabled="False"
                                    ToolTip="Exportar preset a archivo JSON"
                                    Click="ExportPreset_Click"/>
                            <Button x:Name="ImportPresetBtn" Content="Importar" Style="{StaticResource TertiaryButton}"
                                    Padding="10,4" FontSize="11"
                                    ToolTip="Importar preset desde archivo JSON"
                                    Click="ImportPreset_Click"/>
                        </StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="Preset:"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="14,0,8,0"/>
                            <ComboBox x:Name="ExportPresetCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      SelectionChanged="ExportPreset_Changed">
                                <ComboBox.Tag>Seleccionar preset de configuración...</ComboBox.Tag>
                            </ComboBox>
                        </DockPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer x:Name="FormatScroll"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="FormatScroll_ScrollChanged">
                <StackPanel Margin="0,12,0,0">

                    <TextBlock Text="Formatos de exportación"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,10"/>

                    <!-- Format checkboxes -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <CheckBox x:Name="PdfCheck" Content=" PDF"
                                  IsChecked="True" FontSize="12" FontFamily="Segoe UI"
                                  Margin="0,0,24,0"
                                  Checked="FormatCheck_Changed" Unchecked="FormatCheck_Changed"/>
                        <CheckBox x:Name="DwgCheck" Content=" DWG"
                                  IsChecked="True" FontSize="12" FontFamily="Segoe UI"
                                  Checked="FormatCheck_Changed" Unchecked="FormatCheck_Changed"/>
                    </StackPanel>

                    <!-- PDF engine selector (global setting, persisted) -->
                    <Border x:Name="PdfEngineSection"
                            Background="#F0F7FF" CornerRadius="6"
                            Margin="0,0,0,10"
                            BorderBrush="#BBDEFB" BorderThickness="1"
                            Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="Motor PDF (configuración global)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,6"/>
                            <TextBlock FontSize="10" Foreground="#5F6368"
                                       FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,8">
                                Elegí cómo se generan los PDFs. El motor nativo de Revit es rápido pero a veces pierde líneas, textos o tramas.
                                La impresora del sistema (PDF24 recomendado) genera el PDF como si imprimieras el plano desde Revit y suele preservar mejor el contenido.
                            </TextBlock>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Motor:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfEngineCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}"
                                          SelectionChanged="PdfEngine_Changed">
                                    <ComboBoxItem Content="Revit nativo (rápido)" Tag="Native" IsSelected="True"/>
                                    <ComboBoxItem Content="Impresora PDF del sistema" Tag="SystemPrinter"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="PdfPrinterRow" Visibility="Collapsed" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Impresora:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfPrinterCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}"
                                          SelectionChanged="PdfPrinter_Changed"/>
                            </Grid>
                            <TextBlock x:Name="PdfEngineWarning"
                                       Visibility="Collapsed"
                                       FontSize="10" Foreground="#C62828"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                            <TextBlock x:Name="Pdf24DownloadHint"
                                       Visibility="Collapsed"
                                       FontSize="10" Foreground="#5F6368"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Margin="0,4,0,0">
                                <Run Text="¿No tenés PDF24? "/>
                                <Hyperlink x:Name="Pdf24DownloadLink"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           RequestNavigate="Pdf24DownloadLink_RequestNavigate"
                                           NavigateUri="https://tools.pdf24.org/en/creator">
                                    Descargalo gratis →
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- PDF configuration section -->
                    <Border x:Name="PdfSection"
                            Background="#FAFAFA" CornerRadius="6"
                            Margin="0,0,0,10"
                            BorderBrush="#E5E5EA" BorderThickness="1">
                      <Expander IsExpanded="True" Padding="0">
                        <Expander.Header>
                            <TextBlock Text="Configuración PDF"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Segoe UI"/>
                        </Expander.Header>
                        <StackPanel Margin="12,4,12,10">

                            <!-- Paper placement -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ubicación en papel:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfPaperPlacementCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}"
                                          SelectionChanged="PdfPlacement_Changed">
                                    <ComboBoxItem Content="Centrado" Tag="Center" IsSelected="True"/>
                                    <ComboBoxItem Content="Desplazamiento desde esquina" Tag="OffsetFromCorner"/>
                                </ComboBox>
                            </Grid>

                            <!-- Offset X/Y (collapsed by default) -->
                            <Border x:Name="PdfOffsetPanel" Visibility="Collapsed" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Offset X / Y (mm):" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                    <TextBox x:Name="PdfOffsetXBox" Grid.Column="1"
                                             Style="{StaticResource BIMPillsTextBox}"
                                             FontSize="11" Padding="6,4" Text="0"/>
                                    <TextBlock Grid.Column="2" Text=" / " FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                                    <TextBox x:Name="PdfOffsetYBox" Grid.Column="3"
                                             Style="{StaticResource BIMPillsTextBox}"
                                             FontSize="11" Padding="6,4" Text="0"/>
                                </Grid>
                            </Border>

                            <!-- Zoom type -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Escala / Zoom:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfZoomTypeCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}"
                                          SelectionChanged="PdfZoom_Changed">
                                    <ComboBoxItem Content="Ajustar a página" Tag="FitToPage" IsSelected="True"/>
                                    <ComboBoxItem Content="Factor personalizado (%)" Tag="Custom"/>
                                </ComboBox>
                            </Grid>

                            <!-- Zoom % (collapsed by default) -->
                            <Grid x:Name="PdfZoomFactorPanel" Visibility="Collapsed" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Factor (%):" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <TextBox x:Name="PdfZoomFactorBox" Grid.Column="1"
                                         Style="{StaticResource BIMPillsTextBox}"
                                         FontSize="11" Padding="6,4" Text="100"/>
                            </Grid>

                            <!-- Hidden line views processing -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Procesamiento líneas:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfHiddenViewsCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}">
                                    <ComboBoxItem Content="Vectorial (recomendado)" Tag="Vector" IsSelected="True"/>
                                    <ComboBoxItem Content="Raster (sombras/transparencias)" Tag="Raster"/>
                                </ComboBox>
                            </Grid>

                            <!-- Color -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Color:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfColorCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}">
                                    <ComboBoxItem Content="Color" Tag="Color" IsSelected="True"/>
                                    <ComboBoxItem Content="Escala de grises" Tag="Grayscale"/>
                                    <ComboBoxItem Content="Líneas en negro" Tag="BlackLines"/>
                                </ComboBox>
                            </Grid>

                            <!-- Raster quality -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Calidad raster:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <ComboBox x:Name="PdfDpiCombo" Grid.Column="1"
                                          Style="{StaticResource BIMPillsComboBox}">
                                    <ComboBoxItem Content="Baja" Tag="Low"/>
                                    <ComboBoxItem Content="Media (estándar)" Tag="Medium" IsSelected="True"/>
                                    <ComboBoxItem Content="Alta" Tag="High"/>
                                    <ComboBoxItem Content="Presentación (máxima)" Tag="Presentation"/>
                                </ComboBox>
                            </Grid>

                            <!-- Options checkboxes -->
                            <TextBlock Text="Opciones de visibilidad" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <WrapPanel Margin="0,0,0,6">
                                <CheckBox x:Name="PdfHideScopeBoxes" Content=" Ocultar scope boxes"
                                          IsChecked="True" FontSize="11" FontFamily="Segoe UI"
                                          Margin="0,0,16,4"/>
                                <CheckBox x:Name="PdfHideCropBoundaries" Content=" Ocultar crop boundaries"
                                          IsChecked="True" FontSize="11" FontFamily="Segoe UI"
                                          Margin="0,0,16,4"/>
                                <CheckBox x:Name="PdfHideRefPlanes" Content=" Ocultar planos de referencia"
                                          IsChecked="True" FontSize="11" FontFamily="Segoe UI"
                                          Margin="0,0,16,4"/>
                                <CheckBox x:Name="PdfHideUnrefTags" Content=" Ocultar view tags sin referencia"
                                          IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                          Margin="0,0,16,4"/>
                                <CheckBox x:Name="PdfViewLinksBlue" Content=" Links de vista en azul"
                                          IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                          Margin="0,0,16,4"/>
                            </WrapPanel>

                            <!-- Advanced rendering options (content preservation) -->
                            <Expander Header="Opciones avanzadas (preservar contenido)"
                                      FontSize="11" FontFamily="Segoe UI"
                                      Foreground="#3A3A3C"
                                      IsExpanded="False" Margin="0,4,0,0">
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="Si notás que se pierden líneas, textos o tramas en el PDF exportado, dejá estas opciones en OFF (recomendado)."
                                               FontSize="10" Foreground="#86868B"
                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="PdfMaskCoincidentLines"
                                              Content=" Enmascarar líneas coincidentes"
                                              ToolTip="Revit oculta líneas que considera coincidentes. Activarlo puede hacer desaparecer textos finos y anotaciones. Por defecto: OFF."
                                              IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                              Margin="0,0,0,4"/>
                                    <CheckBox x:Name="PdfReplaceHalftones"
                                              Content=" Reemplazar medios tonos por líneas finas"
                                              ToolTip="Convierte tramas/sombras de medios tonos en líneas finas. Puede simplificar áreas sombreadas. Por defecto: OFF."
                                              IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                              Margin="0,0,0,4"/>
                                    <CheckBox x:Name="PdfAlwaysUseRaster"
                                              Content=" Usar siempre raster (garantiza fidelidad visual)"
                                              ToolTip="Fuerza render raster incluso cuando vectorial es posible. Archivo más grande pero preserva sombras/transparencias/materiales complejos. Por defecto: OFF."
                                              IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                              Margin="0,0,0,4"/>
                                </StackPanel>
                            </Expander>

                            <!-- Combine into single PDF -->
                            <Border Background="#EFF3FF" CornerRadius="4" Padding="8,6" BorderBrush="#C5CAE9" BorderThickness="1">
                                <StackPanel>
                                    <CheckBox x:Name="PdfCombineCheck" Content=" Combinar en un solo PDF"
                                              IsChecked="False" FontSize="11" FontFamily="Segoe UI"
                                              Checked="PdfCombine_Changed" Unchecked="PdfCombine_Changed"/>
                                    <Grid x:Name="PdfCombineNamePanel" Visibility="Collapsed" Margin="16,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Nombre archivo:" FontSize="11" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                        <TextBox x:Name="PdfCombinedNameBox" Grid.Column="1"
                                                 Style="{StaticResource BIMPillsTextBox}"
                                                 FontSize="11" Padding="6,4" Text="Planos_Combinados"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                      </Expander>
                    </Border>

                    <!-- DWG setup section -->
                    <Border x:Name="DwgSection"
                            Background="#FAFAFA" CornerRadius="6"
                            Margin="0,0,0,10"
                            BorderBrush="#E5E5EA" BorderThickness="1">
                      <Expander IsExpanded="True" Padding="0">
                        <Expander.Header>
                            <TextBlock Text="Configuración DWG"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Segoe UI"/>
                        </Expander.Header>
                        <StackPanel Margin="12,4,12,10">

                            <!-- Export Setup selector (Revit native) -->
                            <TextBlock Text="Perfil de exportación" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <ComboBox x:Name="DwgSetupCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      Margin="0,0,0,8"/>

                            <!-- Important note (like ProSheets) -->
                            <Border Background="#FFFDE7" CornerRadius="4" Padding="10,7"
                                    BorderBrush="#FFE082" BorderThickness="1" Margin="0,0,0,10">
                                <TextBlock FontSize="11" FontFamily="Segoe UI"
                                           Foreground="#5D4037" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold">Nota:</Run>
                                    <Run>Para crear o modificar perfiles ve a Revit → Exportar → Formatos CAD → DWG → Modificar configuración de exportación.</Run>
                                </TextBlock>
                            </Border>

                            <!-- Extra options -->
                            <CheckBox x:Name="DwgCleanPcpCheck"
                                      Content=" Limpiar archivos .pcp después de exportar"
                                      IsChecked="True" FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                      </Expander>
                    </Border>
                </StackPanel>
                </ScrollViewer>

                <!-- Scroll hint -->
                <Border x:Name="FormatScrollHint"
                        Grid.Row="1"
                        VerticalAlignment="Bottom" Height="48"
                        IsHitTestVisible="False" Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#CCFFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Canvas Width="16" Height="9"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <Polyline Points="0,0 8,8 16,0"
                                  Stroke="#AEAEB2" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════ Tab 3: Exportar ═══════════════ -->
            <TabItem Style="{StaticResource BIMPillsTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Badge3" Style="{StaticResource WizardStepBadge}" Margin="0,0,6,0">
                            <TextBlock x:Name="BadgeText3" Text="3"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="Exportar" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                <StackPanel>

                    <!-- ── Section 1: Carpeta destino ── -->
                    <Expander Style="{StaticResource SectionExpander}"
                              Header="📁  Carpeta destino" IsExpanded="True">
                        <StackPanel Margin="0,8,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Explorar..."
                                        Style="{StaticResource TertiaryButton}"
                                        Padding="14,0"
                                        Margin="8,0,0,0"
                                        Click="BrowseFolder_Click"/>
                                <TextBox x:Name="DestinationBox"
                                         Style="{StaticResource BIMPillsTextBox}"
                                         TextChanged="DestinationBox_TextChanged">
                                    <TextBox.Tag>Seleccionar carpeta de destino...</TextBox.Tag>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── Section 2: Nombramiento ── -->
                    <Expander Style="{StaticResource SectionExpander}"
                              Header="🏷  Nombramiento" IsExpanded="True">
                        <StackPanel Margin="0,8,0,0">
                            <TextBox x:Name="NamingPatternBox"
                                     Style="{StaticResource BIMPillsTextBox}"
                                     Text="{}{SheetNumber}-{SheetName}"
                                     TextChanged="NamingPattern_TextChanged"/>

                            <!-- Built-in token buttons -->
                            <WrapPanel Margin="0,6,0,0">
                                <Button Content="N° Plano" Style="{StaticResource TokenButton}"
                                        Tag="{}{SheetNumber}" Click="InsertToken_Click" Margin="0,0,4,4"/>
                                <Button Content="Nombre" Style="{StaticResource TokenButton}"
                                        Tag="{}{SheetName}" Click="InsertToken_Click" Margin="0,0,4,4"/>
                                <Button Content="Revisión" Style="{StaticResource TokenButton}"
                                        Tag="{}{Revision}" Click="InsertToken_Click" Margin="0,0,4,4"/>
                                <Button Content="Fecha" Style="{StaticResource TokenButton}"
                                        Tag="{}{Date}" Click="InsertToken_Click" Margin="0,0,4,4"/>
                                <Button Content="Proyecto" Style="{StaticResource TokenButton}"
                                        Tag="{}{ProjectName}" Click="InsertToken_Click" Margin="0,0,4,4"/>
                            </WrapPanel>

                            <!-- Revit parameter selector -->
                            <DockPanel Margin="0,6,0,0">
                                <Button DockPanel.Dock="Right"
                                        Content="Agregar"
                                        Style="{StaticResource TertiaryButton}"
                                        Padding="14,0"
                                        Margin="4,0,0,0"
                                        Click="AddParameterToken_Click"/>
                                <ComboBox x:Name="RevitParamsCombo"
                                          Style="{StaticResource BIMPillsComboBox}">
                                    <ComboBox.Tag>Seleccionar parámetro de Revit...</ComboBox.Tag>
                                </ComboBox>
                            </DockPanel>

                            <!-- Dynamic parameter tokens -->
                            <WrapPanel x:Name="DynamicTokensPanel" Margin="0,4,0,0"/>

                            <!-- Preview -->
                            <Border Background="#F8F9FA" CornerRadius="6"
                                    Padding="10,6" Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Vista previa: "
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="NamingPreview"
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <!-- ── Section 3: Organización de carpetas ── -->
                    <Expander Style="{StaticResource SectionExpander}"
                              Header="📂  Organización de carpetas" IsExpanded="False">
                        <StackPanel Margin="0,8,0,0">
                            <ComboBox x:Name="FolderOrgCombo"
                                      Style="{StaticResource BIMPillsComboBox}"
                                      SelectionChanged="FolderOrg_SelectionChanged">
                                <ComboBoxItem Content="Plano (todos en la misma carpeta)" Tag="Flat"/>
                                <ComboBoxItem Content="Por formato (/PDF, /DWG)" Tag="ByFormat" IsSelected="True"/>
                                <ComboBoxItem Content="Por disciplina" Tag="ByDiscipline"/>
                                <ComboBoxItem Content="Formato + Disciplina" Tag="ByFormatAndDiscipline"/>
                            </ComboBox>

                            <!-- Folder structure preview -->
                            <Border Background="#FAFAFA" CornerRadius="6"
                                    Padding="12,10" Margin="0,10,0,0"
                                    BorderBrush="#E5E5EA" BorderThickness="1"
                                    MaxHeight="160">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="FolderPreview"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="#555"
                                               TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Expander>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Progress overlay (overlays TabControl via shared Grid) -->
        <Grid x:Name="ProgressOverlay" Visibility="Collapsed">
            <Border Background="#CC000000" CornerRadius="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="ProgressText"
                               Text="Exportando planos..."
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar x:Name="ProgressBar"
                                 Width="300" Height="8"
                                 Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="ProgressDetail"
                               Text="0 de 0"
                               FontSize="11" Foreground="#CCCCCC"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid>

    </DockPanel>

</UserControl>
