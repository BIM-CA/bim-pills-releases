<Window x:Class="BIMPills.UI.Export.Families.ExportFamiliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Exportar Familias"
        Width="820" Height="640"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para boton primario azul oscuro (exportar) -->
            <Style x:Key="DarkPrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#212B37"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="20,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3A4A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1A2230"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#A0A0A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E5EA"
                BorderThickness="0,0,0,0.5"
                Padding="24,18,24,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/BIMPills.UI;component/Resources/pill-icon.png"
                       Width="28" Height="44"
                       Margin="0,0,14,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Exportar Familias"
                               FontSize="12" FontWeight="Medium"
                               Foreground="#EF6337" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="DocumentName"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="#212B37" FontFamily="Segoe UI"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="SubtitleText"
                               Style="{StaticResource CaptionText}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary bar -->
        <Border Grid.Row="1" Margin="20,16,20,0">
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E5E5EA" BorderThickness="0.5" Padding="20,14">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SummaryText"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="#212B37"/>

                    <Button x:Name="SelectAllButton"
                            Grid.Column="1"
                            Content="Seleccionar todo"
                            Style="{StaticResource TertiaryButton}"
                            Padding="12,5"
                            FontSize="12"
                            Margin="8,0,8,0"
                            Click="SelectAll_Click"/>

                    <TextBlock x:Name="SelectionText"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="#86868B"/>
                </Grid>
            </Border>
        </Border>

        <!-- Main content - DataGrid -->
        <Border Grid.Row="2" Margin="20,16,20,0">
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E5E5EA" BorderThickness="0.5" Padding="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Color="Black"/>
                </Border.Effect>

                <Grid Margin="12,8,12,12">
                    <DataGrid x:Name="FamiliesGrid"
                              Style="{StaticResource BIMPillsDataGrid}"
                              IsReadOnly="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Click="FamilyCheckBox_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Nombre"    Binding="{Binding Name}"     Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="180" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="ExportScrollUpHint"
                               Text="&#x25B2; más familias arriba"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3" Margin="0,28,0,0"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                    <TextBlock x:Name="ExportScrollDownHint"
                               Text="&#x25BC; más familias abajo"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               FontSize="10" FontFamily="Segoe UI" Foreground="#86868B"
                               Background="#EEFFFFFF" Padding="12,3"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Border>

        <!-- Destination bar -->
        <Border Grid.Row="3" Margin="20,12,20,0">
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E5E5EA" BorderThickness="0.5" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Destino:"
                                   VerticalAlignment="Center"
                                   FontSize="13" FontWeight="Medium"
                                   FontFamily="Segoe UI"
                                   Foreground="#212B37"
                                   Margin="0,0,10,0"/>

                        <TextBox x:Name="DestinationPath"
                                 Grid.Column="1"
                                 IsReadOnly="True"
                                 VerticalAlignment="Center"
                                 FontSize="12" FontFamily="Segoe UI"
                                 Foreground="#86868B"
                                 Background="#F9F9FB"
                                 BorderBrush="#E5E5EA"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 Text="Seleccionar carpeta..."
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="2"
                                Content="Examinar..."
                                Style="{StaticResource TertiaryButton}"
                                Padding="14,5"
                                FontSize="12"
                                Click="Browse_Click"/>
                    </Grid>

                    <!-- Version suffix option -->
                    <StackPanel Margin="0,10,0,0">
                        <CheckBox x:Name="VersionSuffixCheck"
                                  FontSize="12" FontFamily="Segoe UI"
                                  Foreground="#212B37"
                                  Checked="VersionSuffixCheck_Changed"
                                  Unchecked="VersionSuffixCheck_Changed">
                            <TextBlock x:Name="VersionSuffixLabel"
                                       Text="Agregar sufijo de versión al nombre de la familia"
                                       FontSize="12" FontFamily="Segoe UI"/>
                        </CheckBox>
                        <Border x:Name="VersionSuffixInfo"
                                Visibility="Collapsed"
                                Background="#F0F4FF"
                                BorderBrush="#BBDEFB"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="20,6,0,0">
                            <TextBlock x:Name="VersionSuffixInfoText"
                                       TextWrapping="Wrap"
                                       FontSize="11" FontFamily="Segoe UI"
                                       Foreground="#1565C0"/>
                        </Border>
                    </StackPanel>

                    <!-- Folder structure preview -->
                    <Expander x:Name="FolderStructureExpander"
                              Header="ESTRUCTURA DE CARPETAS"
                              IsExpanded="False"
                              FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                              Foreground="#86868B"
                              Margin="0,6,0,0">
                        <Border Background="#F9F9FB"
                                BorderBrush="#E5E5EA"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,4,0,0">
                            <TextBlock x:Name="FolderPreviewText"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#3C3C43"
                                       LineHeight="18"/>
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>
        </Border>

        <!-- Footer — Cerrar left, actions right -->
        <Border Grid.Row="4" Padding="24,12,24,16">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="Cerrar (ESC)"
                        Style="{StaticResource PrimaryButton}"
                        Width="120"
                        IsCancel="True"
                        Click="Close_Click"/>

                <Button x:Name="ExportButton"
                        DockPanel.Dock="Right"
                        Content="Exportar seleccionadas"
                        Style="{StaticResource SecondaryButton}"
                        Padding="18,0"
                        IsEnabled="False"
                        Click="Export_Click"/>
            </DockPanel>
        </Border>

        <!-- Progress overlay -->
        <Grid x:Name="ProgressOverlay"
              Grid.Row="0" Grid.RowSpan="5"
              Visibility="Collapsed">
            <Border Background="#CC000000">
                <Border Background="White" CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="40,30"
                        MinWidth="350">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="16" Opacity="0.2" Color="Black"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ProgressText"
                                   Text="Exportando..."
                                   FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#212B37"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <ProgressBar x:Name="ProgressBar"
                                     Width="280" Height="8"
                                     Minimum="0" Maximum="100"
                                     Foreground="#EF6337"
                                     Background="#E5E5EA"/>
                        <TextBlock x:Name="ProgressDetail"
                                   Text=""
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   Foreground="#86868B"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
