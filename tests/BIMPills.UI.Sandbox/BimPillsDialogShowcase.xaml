<Window x:Class="BIMPills.UI.Sandbox.BimPillsDialogShowcase"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Pills — Diálogos (Showcase)"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BIMPills.UI;component/Shared/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Header -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="BimPillsDialog — Showcase"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Todos los diálogos comparten la misma base visual. Sólo cambian el badge de estado, el texto y los botones."
                           FontSize="12"
                           Foreground="#86868B"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Variantes -->
        <TextBlock Text="VARIANTES (DialogKind)"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#86868B" FontFamily="Segoe UI"
                   Margin="4,0,0,8"/>

        <UniformGrid Columns="2">
            <Button Content="ℹ️  Info"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,4,6" Height="34"
                    Click="Info_Click"/>
            <Button Content="✅  Success"
                    Style="{StaticResource SecondaryButton}"
                    Margin="4,0,0,6" Height="34"
                    Click="Success_Click"/>
            <Button Content="⚠️  Warning"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,4,6" Height="34"
                    Click="Warning_Click"/>
            <Button Content="❌  Error"
                    Style="{StaticResource SecondaryButton}"
                    Margin="4,0,0,6" Height="34"
                    Click="Error_Click"/>
        </UniformGrid>

        <!-- Confirmaciones -->
        <TextBlock Text="CONFIRMACIONES"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#86868B" FontFamily="Segoe UI"
                   Margin="4,16,0,8"/>

        <Button Content="❓  Confirm — ¿Iniciar exportación? (caso real)"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ConfirmExport_Click"/>

        <Button Content="🗑  Confirm — ¿Eliminar conjunto? (warning)"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ConfirmDelete_Click"/>

        <Button Content="🔀  YesNoCancel — Cambios sin guardar"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="YesNoCancel_Click"/>

        <!-- Casos con detalle -->
        <TextBlock Text="CON DETALLE (bloque secundario)"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#86868B" FontFamily="Segoe UI"
                   Margin="4,16,0,8"/>

        <Button Content="✅  Success con detalle largo"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="SuccessDetail_Click"/>

        <Button Content="❌  Error con stack trace simulado"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ErrorDetail_Click"/>

        <!-- Ventanas de proceso -->
        <TextBlock Text="VENTANAS DE PROCESO (BimPillsProgressWindow)"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#86868B" FontFamily="Segoe UI"
                   Margin="4,16,0,8"/>

        <Button Content="⏳  Progreso — Exportar 20 planos (rápido)"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ProgressFast_Click"/>

        <Button Content="🐢  Progreso — Exportar 8 modelos (lento, con fallos)"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ProgressSlow_Click"/>

        <Button Content="🛑  Progreso — Cancelable a mitad de proceso"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="34"
                Click="ProgressCancellable_Click"/>

        <!-- Resultado -->
        <Border Background="#F5F5F7"
                BorderBrush="#E5E5EA"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10"
                Margin="0,16,0,0">
            <TextBlock x:Name="ResultText"
                       Text="Último resultado: (ninguno)"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       Foreground="#3A3A3C"
                       TextWrapping="Wrap"/>
        </Border>

    </StackPanel>
</Window>
